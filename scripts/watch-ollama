#!/usr/bin/env python3
import curses
import subprocess
import time
import threading
import os
import pathlib
import sys

# Resolve paths
SCRIPTS_DIR = pathlib.Path(__file__).resolve().parent
sys.path.append(str(SCRIPTS_DIR))

# Import modular components
from log_indexer import LogIndexer
from config_manager import ConfigManager
from selection_manager import SelectionManager
import telemetry_utils as telemetry
import ui_utils as ui

# Primary installation directory
INSTALL_DIR = pathlib.Path.home() / ".ollama-watch-tool"

HEADER_FILE = SCRIPTS_DIR / "header.txt"
HEADER_SMALL_FILE = SCRIPTS_DIR / "header_small.txt"

# Primary log location
READABLE_LOG = str(SCRIPTS_DIR.parent / "ollama_readable.log")
if not os.path.exists(READABLE_LOG) and (INSTALL_DIR / "ollama_readable.log").exists():
    READABLE_LOG = str(INSTALL_DIR / "ollama_readable.log")

# Managers
config = ConfigManager(INSTALL_DIR, SCRIPTS_DIR)
selection = SelectionManager()
log_indexer = LogIndexer(READABLE_LOG)

# Constants & State
LOG_WINDOW_SIZE = 3000
log_cache = {}
thought_cache = {} # abs_idx -> bool
log_lock = threading.Lock()
log_ready = threading.Event()
log_version = 0
last_log_update = time.time()
error_messages = {}
error_lock = threading.Lock()
render_event = threading.Event()
MOUSE_ENABLED = True
SCROLL_LINE_STEP = 3
STARTUP_LOGO_SECONDS = 2.0
IDLE_WAIT_AFTER_INPUT = 0.04
IDLE_WAIT_DEFAULT = 0.15
SMI_RESET_FRAMES = 10
_tail_proc = None

def set_error(key, message):
    with error_lock:
        if message: error_messages[key] = ui.sanitize_render_text(message)
        else: error_messages.pop(key, None)
    render_event.set()

def get_error_lines(width):
    with error_lock: messages = list(error_messages.values())
    if not messages: return []
    text = " | ".join(messages)
    return ui.wrap_render_line(text, width)

def get_cached_log_entry(abs_idx, raw_content, width):
    entry = log_cache.get(abs_idx)
    if not entry or entry["raw"] != raw_content:
        sanitized = ui.sanitize_render_text(raw_content)
        in_thought = line_is_in_thought(abs_idx)
        entry = {"raw": raw_content, "sanitized": sanitized, "wrapped": {}, "in_thought": in_thought}
        log_cache[abs_idx] = entry
    if width not in entry["wrapped"]:
        entry["wrapped"][width] = ui.wrap_render_line(entry["sanitized"], width)
    return entry

def line_is_in_thought(source_idx):
    if source_idx in thought_cache: return thought_cache[source_idx]
    in_thought = False
    # Only scan back 500 lines
    for j in range(source_idx, max(-1, source_idx - 500), -1):
        if j in thought_cache:
            in_thought = thought_cache[j]
            break
        check_line = ui.sanitize_render_text(log_indexer.get_line(j))
        if ui.line_opens_thought(check_line):
            if ui.line_closes_thought(check_line):
                in_thought = max(check_line.rfind("</think>"), check_line.rfind("[/THOUGHT]")) < max(
                    check_line.rfind("<think>"), check_line.rfind("[THOUGHT]"))
            else: in_thought = True
            break
        if ui.line_closes_thought(check_line) or ui.is_separator_line(check_line):
            in_thought = False
            break
    thought_cache[source_idx] = in_thought
    return in_thought

def build_visible_log_window(scroll_pos, scroll_offset, log_h, width):
    visible = []
    curr_raw, curr_off = scroll_pos, scroll_offset
    total_raw = len(log_indexer)
    while len(visible) < log_h and curr_raw < total_raw:
        raw_content = log_indexer.get_line(curr_raw)
        entry = get_cached_log_entry(curr_raw, raw_content, width)
        segments = entry["wrapped"][width]
        for i in range(curr_off, len(segments)):
            visible.append((curr_raw, i, segments[i], entry))
            if len(visible) >= log_h: break
        curr_raw += 1
        curr_off = 0
    if len(log_cache) > LOG_WINDOW_SIZE * 2:
        current_range = set(range(max(0, scroll_pos - 1000), min(total_raw, scroll_pos + LOG_WINDOW_SIZE + 1000)))
        for k in list(log_cache.keys()):
            if k not in current_range:
                del log_cache[k]
                if k in thought_cache: del thought_cache[k]
    return visible

def get_line_segments_count(raw_idx, width):
    if raw_idx < 0 or raw_idx >= len(log_indexer): return 0
    raw = log_indexer.get_line(raw_idx)
    entry = get_cached_log_entry(raw_idx, raw, width)
    return len(entry["wrapped"][width])

def find_scroll_start_for_bottom(log_h, width):
    total_raw = len(log_indexer)
    if total_raw == 0: return 0, 0
    lines_needed, curr_raw = log_h, total_raw - 1
    raw = log_indexer.get_line(curr_raw)
    entry = get_cached_log_entry(curr_raw, raw, width)
    segments = entry["wrapped"][width]
    if len(segments) >= lines_needed: return curr_raw, len(segments) - lines_needed
    lines_needed -= len(segments)
    while lines_needed > 0 and curr_raw > 0:
        curr_raw -= 1
        raw = log_indexer.get_line(curr_raw)
        entry = get_cached_log_entry(curr_raw, raw, width)
        segments = entry["wrapped"][width]
        if len(segments) >= lines_needed: return curr_raw, len(segments) - lines_needed
        lines_needed -= len(segments)
    return 0, 0

def collect_input(stdscr):
    keys = []
    while True:
        key = stdscr.getch()
        if key == -1: return keys
        keys.append(key)

def apply_input(stdscr, keys, scroll_pos, scroll_offset, auto_scroll, log_h, render_width, smi_lines, visible_log_window):
    total_raw = len(log_indexer)
    changed, smi_changed = False, False
    if keys:
        for key in keys:
            if key == 3: # Ctrl+C
                if selection.start and selection.end:
                    text = selection.get_selected_text(log_indexer)
                    if text:
                        selection.copy_to_clipboard(text)
                        selection.clear()
                        changed = True
                else: return scroll_pos, scroll_offset, auto_scroll, True, False, True
            elif key == curses.KEY_UP:
                for _ in range(SCROLL_LINE_STEP):
                    if scroll_offset > 0: scroll_offset -= 1; changed = True
                    elif scroll_pos > 0:
                        scroll_pos -= 1
                        scroll_offset = max(0, get_line_segments_count(scroll_pos, render_width) - 1)
                        changed = True
                if changed: auto_scroll = False
            elif key == curses.KEY_DOWN:
                for _ in range(SCROLL_LINE_STEP):
                    seg_count = get_line_segments_count(scroll_pos, render_width)
                    if scroll_offset < seg_count - 1: scroll_offset += 1; changed = True
                    elif scroll_pos < total_raw - 1: scroll_pos += 1; scroll_offset = 0; changed = True
                if changed:
                    if scroll_pos >= total_raw - 1 and scroll_offset >= get_line_segments_count(scroll_pos, render_width) - 1: auto_scroll = True
                    else: auto_scroll = False
            elif key == curses.KEY_PPAGE:
                for _ in range(log_h):
                    if scroll_offset > 0: scroll_offset -= 1
                    elif scroll_pos > 0:
                        scroll_pos -= 1
                        scroll_offset = max(0, get_line_segments_count(scroll_pos, render_width) - 1)
                    else: break
                auto_scroll, changed = False, True
            elif key == curses.KEY_NPAGE:
                for _ in range(log_h):
                    seg_count = get_line_segments_count(scroll_pos, render_width)
                    if scroll_offset < seg_count - 1: scroll_offset += 1
                    elif scroll_pos < total_raw - 1: scroll_pos += 1; scroll_offset = 0
                    else: auto_scroll = True; break
                changed = True
            elif key == curses.KEY_HOME: scroll_pos, scroll_offset, auto_scroll, changed = 0, 0, False, True
            elif key == curses.KEY_END:
                scroll_pos, scroll_offset = find_scroll_start_for_bottom(log_h, render_width)
                auto_scroll, changed = True, True
            elif key == ord('f') or key == ord('F'):
                auto_scroll = not auto_scroll
                changed = True
                if auto_scroll: scroll_pos, scroll_offset = find_scroll_start_for_bottom(log_h, render_width)
            elif key == ord('g') or key == ord('G'):
                config.save_setting("show_gpu", not config.settings["show_gpu"])
                changed, smi_changed = True, True
                telemetry.smi_poll_trigger.set()
            elif key == ord('c') or key == ord('C'):
                config.save_setting("show_cpu", not config.settings["show_cpu"])
                changed, smi_changed = True, True
                telemetry.smi_poll_trigger.set()
            elif key == ord('l') or key == ord('L'):
                config.save_setting("show_log", not config.settings["show_log"])
                changed, smi_changed = True, True
            elif key == ord('h') or key == ord('H'):
                config.save_setting("show_hints", not config.settings["show_hints"])
                changed = True
            elif key == ord('t') or key == ord('T'):
                telemetry.detect_gpu_tool(telemetry.GPU_TOOLS[(telemetry.GPU_TOOLS.index(config.settings["gpu_tool"]) + 1) % len(telemetry.GPU_TOOLS)])
                # This needs better integration, but for now:
                curr = config.settings["gpu_tool"]
                new_tool = telemetry.GPU_TOOLS[(telemetry.GPU_TOOLS.index(curr) + 1) % len(telemetry.GPU_TOOLS)]
                config.save_setting("gpu_tool", new_tool)
                changed, smi_changed = True, True
                telemetry.smi_poll_trigger.set()
            elif key == 19: # Ctrl+S
                toggle_mouse(stdscr, not MOUSE_ENABLED)
                changed = True
            elif key == curses.KEY_MOUSE:
                try:
                    _, mx, my, _, bstate = curses.getmouse()
                    if bstate & 0x10000: # Scroll up
                        for _ in range(SCROLL_LINE_STEP):
                            if scroll_offset > 0: scroll_offset -= 1
                            elif scroll_pos > 0:
                                scroll_pos -= 1
                                scroll_offset = max(0, get_line_segments_count(scroll_pos, render_width) - 1)
                        auto_scroll, changed = False, True
                    elif bstate & 0x200000: # Scroll down
                        for _ in range(SCROLL_LINE_STEP):
                            seg_count = get_line_segments_count(scroll_pos, render_width)
                            if scroll_offset < seg_count - 1: scroll_offset += 1
                            elif scroll_pos < total_raw - 1: scroll_pos += 1; scroll_offset = 0
                        changed = True
                    log_y_start = smi_lines + 1
                    if bstate & curses.BUTTON1_PRESSED:
                        if log_y_start <= my < log_y_start + log_h:
                            view_idx = my - log_y_start
                            if view_idx < len(visible_log_window):
                                raw_idx, seg_off, _, _ = visible_log_window[view_idx]
                                selection.start = selection.end = (raw_idx, seg_off, mx)
                                selection.active, changed = True, True
                        else: selection.active, selection.start, selection.end, changed = False, None, None, True
                    elif bstate & curses.REPORT_MOUSE_POSITION and selection.active:
                        if log_y_start <= my < log_y_start + log_h:
                            view_idx = my - log_y_start
                            if view_idx < len(visible_log_window):
                                raw_idx, seg_off, _, _ = visible_log_window[view_idx]
                                selection.end, changed = (raw_idx, seg_off, mx), True
                except curses.error: pass
    if auto_scroll:
        pass # Recalculated in main loop for better stability
    else:
        if scroll_pos >= total_raw: scroll_pos = max(0, total_raw - 1)
        seg_count = get_line_segments_count(scroll_pos, render_width)
        if scroll_offset >= seg_count: scroll_offset = max(0, seg_count - 1)
    return scroll_pos, scroll_offset, auto_scroll, changed, smi_changed, False

def tail_log():
    global last_log_update, log_version, _tail_proc
    try:
        # tail -f with a small buffer for responsiveness
        _tail_proc = subprocess.Popen(
            ['tail', '-f', '-n', '0', READABLE_LOG],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            bufsize=0  # unbuffered
        )
        # Set non-blocking on stdout
        fd = _tail_proc.stdout.fileno()
        os.set_blocking(fd, False)
        
        log_ready.set()
        while True:
            try:
                # Read whatever is available
                chunk = _tail_proc.stdout.read(4096)
                if chunk:
                    last_log_update = time.time()
                    with log_lock:
                        if log_indexer.update(): log_version += 1
                    render_event.set()
                else:
                    if _tail_proc.poll() is not None: break
                    time.sleep(0.05)
            except (BlockingIOError, TypeError):
                time.sleep(0.05)
    except Exception as e: set_error("log", f"Log tail error: {e}"); log_ready.set()

def toggle_mouse(stdscr, enable):
    global MOUSE_ENABLED
    MOUSE_ENABLED = enable
    if enable:
        curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
        print("\033[?1003h", end="")
    else:
        curses.mousemask(0)
        print("\033[?1003l", end="")
    stdscr.refresh()

def render_log_line_with_selection(stdscr, y, line, raw_idx, seg_off, render_width, default_color):
    for x in range(render_width):
        char = line[x] if x < len(line) else ' '
        color = (curses.color_pair(4) | curses.A_REVERSE) if selection.is_pos_in_selection(raw_idx, seg_off, x) else default_color
        try: stdscr.addch(y, x, char, color)
        except curses.error: pass

def main(stdscr):
    try:
        with open(HEADER_FILE, "r") as f: header_full = f.read().splitlines() + ["", "Welcome to watch-ollama. Press 'q' to quit."]
    except FileNotFoundError: header_full = ["WATCH OLLAMA", "", "Welcome to watch-ollama. Press 'q' to quit."]
    try:
        with open(HEADER_SMALL_FILE, "r") as f: header_small = f.read().splitlines() + ["", "Welcome to watch-ollama. Press 'q' to quit."]
    except FileNotFoundError: header_small = ["WATCH OLLAMA", "", "Welcome to watch-ollama. Press 'q' to quit."]
    
    curses.curs_set(0); stdscr.nodelay(1); stdscr.keypad(True); stdscr.timeout(0)
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
    curses.start_color(); curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1); curses.init_pair(2, curses.COLOR_GREEN, -1)
    curses.init_pair(3, curses.COLOR_YELLOW, -1); curses.init_pair(4, curses.COLOR_MAGENTA, -1)
    curses.init_pair(11, curses.COLOR_RED, -1); curses.init_pair(5, curses.COLOR_BLUE, -1)
    if curses.COLORS >= 256: curses.init_pair(6, 208, -1)
    else: curses.init_pair(6, curses.COLOR_YELLOW, -1)
    
    threading.Thread(target=tail_log, daemon=True).start()
    threading.Thread(target=telemetry.poll_smi, args=(config.settings, set_error, render_event), daemon=True).start()

    startup_until = time.time() + STARTUP_LOGO_SECONDS
    while time.time() < startup_until:
        max_y, max_x = stdscr.getmaxyx(); stdscr.erase()
        header = header_full if max_x > 120 else header_small
        start_y = max(0, (max_y - len(header)) // 2)
        for i, line in enumerate(header):
            y = start_y + i
            if y >= max_y: break
            x = max(0, (max_x - len(ui.visible_ansi_text(line))) // 2)
            ui.render_ansi_line(stdscr, y, x, line, max_x - 1)
        stdscr.refresh()
        if stdscr.getch() in [3, ord('q'), ord('Q'), 27]: return
        time.sleep(0.05)

    scroll_pos, scroll_offset, auto_scroll = 0, 0, True
    reserved_smi_lines_by_height, smi_reset_counter = {}, 0
    render_dirty = True
    last_term_size, last_smi_ver, last_log_ver = (-1, -1), -1, -1
    last_error_sig, last_scroll, last_auto, input_was_active = (), (-1, -1), None, False

    # State for auto-scroll stability
    last_known_total_raw = -1
    last_known_last_line_len = -1

    while True:
        # ── IDLE WAIT ────────────────────────────────────────────────────
        if not render_dirty:
            wait_s = 0.02 if (time.time() - last_log_update < 1.0) else (IDLE_WAIT_AFTER_INPUT if input_was_active else IDLE_WAIT_DEFAULT)
            render_event.wait(timeout=wait_s); render_event.clear()
        keys = collect_input(stdscr)
        if any(k in [3, ord('q'), ord('Q'), 27] for k in keys): break

        max_y, max_x = stdscr.getmaxyx()
        if (max_y, max_x) != last_term_size: stdscr.clear()
        smi_snapshot, cpu_temp, curr_smi_ver = telemetry.get_smi_snapshot()
        render_width = max(1, max_x - 1)
        active_errors = get_error_lines(render_width); error_h = min(2, len(active_errors))
        
        with log_lock:
            curr_log_ver = log_version
            total_raw = len(log_indexer)
            # Efficiently check if last line changed without full read if possible
            # But get_line is fast enough with open file handle
            last_line = log_indexer.get_line(total_raw - 1) if total_raw > 0 else ""
            curr_last_line_len = len(last_line)

        # ── LAYOUT ───────────────────────────────────────────────────────
        max_smi = max(5, (max_y * 2) // 3) if config.settings["show_log"] else max(5, max_y - error_h - 2)
        if smi_reset_counter > 0: reserved_smi_lines_by_height.clear(); smi_reset_counter -= 1
        smi_lines = reserved_smi_lines_by_height.get(max_y, 0)
        if smi_lines == 0:
            smi_lines = min(max_smi, max(12, len(smi_snapshot))) if config.settings["show_gpu"] else min(max_smi, len(smi_snapshot))
        reserved_smi_lines_by_height[max_y] = smi_lines
        log_h = max(1, max_y - smi_lines - error_h - 2) if config.settings["show_log"] else 0
        if not config.settings["show_log"]: smi_lines = max_y - error_h - 1

        # Check for changes that should trigger auto-scroll update
        if auto_scroll:
            if total_raw != last_known_total_raw or curr_last_line_len != last_known_last_line_len:
                scroll_pos, scroll_offset = find_scroll_start_for_bottom(log_h, render_width)
                last_known_total_raw = total_raw
                last_known_last_line_len = curr_last_line_len

        scroll_pos, scroll_offset, auto_scroll, input_changed, smi_changed, quit_req = apply_input(
            stdscr, keys, scroll_pos, scroll_offset, auto_scroll, log_h, render_width, smi_lines, 
            build_visible_log_window(scroll_pos, scroll_offset, log_h, render_width))
        if quit_req: break
        if smi_changed or input_changed:
            stdscr.clear()
            if smi_changed: smi_reset_counter = SMI_RESET_FRAMES
        input_was_active = bool(input_changed)
        visible_log_window = build_visible_log_window(scroll_pos, scroll_offset, log_h, render_width)

        if (input_changed or (max_y, max_x) != last_term_size or curr_smi_ver != last_smi_ver or 
            curr_log_ver != last_log_ver or tuple(active_errors) != last_error_sig or 
            (scroll_pos, scroll_offset) != last_scroll or auto_scroll != last_auto):
            render_dirty = True
        if not render_dirty: continue

        for i in range(smi_lines):
            line = smi_snapshot[i] if i < len(smi_snapshot) else ""
            if "CPU:" in line and ("RAM:" in line or "°C" in line):
                parts, curr_x = line.split(" | "), 0
                for idx, part in enumerate(parts):
                    if idx > 0:
                        try: stdscr.addstr(i, curr_x, " | "); curr_x += 3
                        except curses.error: break
                    if part.startswith("CPU:"):
                        try: stdscr.addstr(i, curr_x, "CPU:", curses.A_BOLD); curr_x += 4
                        except curses.error: break
                        sub = part[4:].strip().split()
                        for item in sub:
                            val_str = item.replace("%", "").replace("°C", "")
                            try:
                                val = float(val_str); col = ui.get_temp_color(val) if "°C" in item else ui.get_val_color(val, 25, 50, 75, 90)
                                if "°C" in item:
                                    stdscr.addstr(i, curr_x, " 🌡 ", curses.A_REVERSE | col); curr_x += 3
                                stdscr.addstr(i, curr_x, " " + item, col); curr_x += len(item) + 1
                            except ValueError:
                                stdscr.addstr(i, curr_x, " " + item); curr_x += len(item) + 1
                    elif part.startswith("RAM:"):
                        try: stdscr.addstr(i, curr_x, "RAM:", curses.A_BOLD); curr_x += 4
                        except curses.error: break
                        r_val = part[4:].strip()
                        if "/" in r_val:
                            try:
                                u, t = map(float, [re.sub(r'[^0-9.]', '', s) for s in r_val.split('/')])
                                pct = (u/t)*100 if t>0 else 0; col = ui.get_val_color(pct, 25, 50, 75, 90)
                                if pct > 75: stdscr.addstr(i, curr_x, " !! ", curses.A_REVERSE | col); curr_x += 4
                                stdscr.addstr(i, curr_x, " " + r_val, col); curr_x += len(r_val) + 1
                            except Exception: stdscr.addstr(i, curr_x, " " + r_val); curr_x += len(r_val) + 1
                    else:
                        for s_p in part.split():
                            if ":" in s_p:
                                try:
                                    n, v = s_p.split(":"); stdscr.addstr(i, curr_x, n + ":", curses.A_BOLD); curr_x += len(n)+1
                                    col = ui.get_temp_color(float(v.replace("°C", ""))); stdscr.addstr(i, curr_x, v, col); curr_x += len(v)
                                except Exception: stdscr.addstr(i, curr_x, s_p); curr_x += len(s_p)
                            else: stdscr.addstr(i, curr_x, s_p); curr_x += len(s_p)
                            stdscr.addstr(i, curr_x, " "); curr_x += 1
                try: stdscr.clrtoeol()
                except curses.error: pass
            else: ui.render_ansi_line(stdscr, i, 0, line, max_x - 1)

        if smi_lines < max_y:
            try: stdscr.addstr(smi_lines, 0, ("-" * (max_x-1))[:max_x-1], curses.A_REVERSE)
            except curses.error: pass
        if config.settings["show_log"]:
            for i in range(log_h):
                if i < len(visible_log_window):
                    abs_idx, seg_off, line, entry = visible_log_window[i]
                    render_log_line_with_selection(stdscr, smi_lines + 1 + i, line, abs_idx, seg_off, render_width, ui.render_attr_for_log_line(entry, line))
                else:
                    try: stdscr.addstr(smi_lines + 1 + i, 0, " " * render_width)
                    except curses.error: pass
        error_start = max_y - 1 - error_h
        for i in range(error_h):
            y = error_start + i
            if y >= 0:
                try: stdscr.addstr(y, 0, (" " + active_errors[i]).ljust(render_width)[:render_width], curses.color_pair(3) | curses.A_BOLD)
                except curses.error: pass
        if max_y > 0:
            status = f" [{'FOLLOWING' if auto_scroll else 'PAUSED'}] (Line {scroll_pos}/{len(log_indexer)}){' (G:GPU C:CPU L:Log H:Hint T:Tool S:Mouse | F:Follow | Q:Quit) ' if config.settings['show_hints'] else ''}"
            try:
                stdscr.addstr(max_y-1, 0, status.ljust(max_x-1)[:max_x-1], curses.A_REVERSE)
                pos = max_x - 22
                if pos > len(status) + 2:
                    stdscr.addstr(max_y-1, pos, " 🌡 ", curses.A_REVERSE | ui.get_temp_color(cpu_temp))
                    if active_errors: stdscr.addstr(max_y-1, pos+4, " ⚠️ ", curses.color_pair(11) | curses.A_REVERSE)
                    la = (time.time() - last_log_update < 2.0); lt = "output" if la else "idle"; lc = curses.color_pair(2) if la else curses.color_pair(3)
                    stdscr.addstr(max_y-1, pos+9, f" {lt} ", curses.A_REVERSE | lc)
            except curses.error: pass
            m = "🟦" if cpu_temp < 35 else "🟩" if cpu_temp < 55 else "🟨" if cpu_temp < 70 else "🟧" if cpu_temp < 85 else "🟥"
            sys.stdout.write(f"\033]0;👀 Watch Ollama {m}{' ⚠️' if active_errors else ''}{' output' if (time.time()-last_log_update<2.0) else ' idle'}\007"); sys.stdout.flush()
        stdscr.refresh(); last_term_size, last_smi_ver, last_log_ver = (max_y, max_x), curr_smi_ver, curr_log_ver
        last_error_sig, last_scroll, last_auto, render_dirty = tuple(active_errors), (scroll_pos, scroll_offset), auto_scroll, False

if __name__ == "__main__":
    import re
    sys.stdout.write("\033]0;👀 Watch Ollama\007"); sys.stdout.flush()
    try: curses.wrapper(main)
    except KeyboardInterrupt: pass
    finally:
        print("\033[?1003l", end="")
        log_indexer.close()
        if _tail_proc:
            try: _tail_proc.terminate()
            except Exception: pass
