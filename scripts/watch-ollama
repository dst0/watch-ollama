#!/usr/bin/env python3
import curses
import subprocess
import time
import threading
import os
from collections import deque
import urllib.request
import json

log_lines = deque(maxlen=5000)
smi_text = ["Loading GPU status..."]

def tail_log():
    import fcntl
    try:
        p = subprocess.Popen(['tail', '-f', '-n', '2000', '/var/log/ollama_readable.log'], stdout=subprocess.PIPE)
        fd = p.stdout.fileno()
        fl = fcntl.fcntl(fd, fcntl.F_GETFL)
        fcntl.fcntl(fd, fcntl.F_SETFL, fl | os.O_NONBLOCK)
        
        current_line = ""
        while True:
            try:
                chunk_bytes = p.stdout.read(4096)
            except BlockingIOError:
                chunk_bytes = None
            
            if chunk_bytes:
                try:
                    text = chunk_bytes.decode('utf-8', errors='replace')
                except Exception:
                    text = ""
                
                parts = text.split('\n')
                if len(parts) == 1:
                    current_line += parts[0]
                    if log_lines:
                        log_lines[-1] = current_line.replace('\t', '    ')
                    else:
                        log_lines.append(current_line.replace('\t', '    '))
                else:
                    current_line += parts[0]
                    if log_lines:
                        log_lines[-1] = current_line.replace('\t', '    ')
                    else:
                        log_lines.append(current_line.replace('\t', '    '))
                    
                    for part in parts[1:-1]:
                        log_lines.append(part.replace('\t', '    '))
                    
                    current_line = parts[-1]
                    log_lines.append(current_line.replace('\t', '    '))
            else:
                time.sleep(0.05)
    except Exception as e:
        log_lines.append(f"Error tailing log: {e}")

def get_ollama_num_parallel():
    """Return OLLAMA_NUM_PARALLEL from the current env or the running ollama process env."""
    val = os.environ.get("OLLAMA_NUM_PARALLEL")
    if val:
        return val
    try:
        pid_out = subprocess.check_output(['pgrep', '-x', 'ollama'], text=True, timeout=2).strip()
        if pid_out:
            pid = pid_out.splitlines()[0].strip()
            with open(f'/proc/{pid}/environ', 'rb') as f:
                env_data = f.read()
            for entry in env_data.split(b'\x00'):
                if entry.startswith(b'OLLAMA_NUM_PARALLEL='):
                    return entry.split(b'=', 1)[1].decode()
    except Exception:
        pass
    return "auto"

def parse_ollama_ps():
    """Run 'ollama ps' and return a dict of model_name -> processor_string."""
    result = {}
    try:
        ps_output = subprocess.check_output(['ollama', 'ps'], text=True, errors="replace", timeout=3)
        ps_lines = ps_output.strip().splitlines()
        if len(ps_lines) < 2:
            return result
        header_line = ps_lines[0].upper()
        proc_col = header_line.find("PROCESSOR")
        until_col = header_line.find("UNTIL")
        if proc_col < 0:
            return result
        for row in ps_lines[1:]:
            if not row.strip():
                continue
            name_field = row[:proc_col].strip()
            name = name_field.split()[0] if name_field else ""
            if until_col > proc_col:
                processor = row[proc_col:until_col].strip()
            else:
                processor = row[proc_col:].strip()
            if name:
                result[name] = processor
    except Exception:
        pass
    return result

def poll_smi():
    global smi_text
    while True:
        # amd-smi output
        try:
            output = subprocess.check_output(['amd-smi'], text=True, errors="replace")
            hw_lines = output.splitlines()
        except Exception:
            hw_lines = ["(amd-smi unavailable)"]

        # Parallel sessions allowed
        num_parallel = get_ollama_num_parallel()

        # GPU/CPU split from 'ollama ps'
        ps_info = parse_ollama_ps()

        # Model details from /api/ps
        model_lines = []
        try:
            req = urllib.request.Request("http://127.0.0.1:11435/api/ps", method="GET")
            with urllib.request.urlopen(req, timeout=1) as response:
                data = json.loads(response.read().decode())
                models = data.get("models", [])
                if models:
                    for m in models:
                        name = m.get("name", "unknown")
                        ctx = m.get("context_length", 0)
                        size = m.get("size", 0)
                        size_vram = m.get("size_vram", 0)

                        # GPU/CPU split: prefer 'ollama ps', fall back to size_vram ratio
                        processor = ps_info.get(name, "")
                        if not processor and size > 0:
                            gpu_pct = int(round(size_vram / size * 100))
                            cpu_pct = 100 - gpu_pct
                            processor = f"{gpu_pct}% GPU / {cpu_pct}% CPU"

                        size_str = f"{size / (1024**3):.1f} GB" if size > 0 else "? GB"
                        model_lines.append(
                            f"  {name}  |  {size_str}  |  {processor or 'unknown'}  |  ctx: {ctx}"
                        )
                else:
                    model_lines = ["  (no active models)"]
        except Exception:
            model_lines = ["  (could not reach Ollama API)"]

        header = f"=== OLLAMA  parallel:{num_parallel} ==="
        smi_text = [header] + model_lines + [""] + hw_lines
        time.sleep(0.5)

def main(stdscr):
    # Load ASCII Header
    try:
        with open(os.path.expanduser("~/.ollama-watch-tool/scripts/header.txt"), "r") as f:
            header_lines = f.read().splitlines()
    except FileNotFoundError:
        header_lines = ["WATCH OLLAMA", "Monitoring, Benchmarking, & Management Suite"]
    
    header = header_lines + ["", "Welcome to watch-ollama. Press 'q' to quit."]
    
    curses.curs_set(0)
    stdscr.nodelay(1)
    stdscr.keypad(True)
    stdscr.timeout(50)
    
    # Show header briefly or wait for input if you like, 
    # but here we'll just incorporate it into the loop setup
    # ... rest of your code ...
    curses.init_pair(1, curses.COLOR_CYAN, -1)     # USER block
    curses.init_pair(2, curses.COLOR_GREEN, -1)    # ASSISTANT block
    curses.init_pair(3, curses.COLOR_YELLOW, -1)   # Separators
    curses.init_pair(4, curses.COLOR_MAGENTA, -1)  # THOUGHT block
    
    t_log = threading.Thread(target=tail_log, daemon=True)
    t_log.start()
    
    t_smi = threading.Thread(target=poll_smi, daemon=True)
    t_smi.start()

    scroll_pos = 0
    auto_scroll = True

    while True:
        max_y, max_x = stdscr.getmaxyx()
        
        # Estimate how many lines amd-smi takes
        smi_lines = len(smi_text) if len(smi_text) > 0 else 15
        if smi_lines > max_y // 2:
            smi_lines = max_y // 2
            
        log_h = max_y - smi_lines - 2
        if log_h < 1:
            log_h = 1 # Prevent crash on tiny terminal

        # Handle input
        key = stdscr.getch()
        
        if key != -1:
            if key == 3 or key == ord('q') or key == ord('Q') or key == 27: # Ctrl+C, q, Q, ESC
                break
            elif key == curses.KEY_UP:
                scroll_pos = max(0, scroll_pos - 1)
                auto_scroll = False
            elif key == curses.KEY_DOWN:
                scroll_pos += 1
                if scroll_pos >= max(0, len(log_lines) - log_h):
                    auto_scroll = True
            elif key == curses.KEY_PPAGE:
                scroll_pos = max(0, scroll_pos - log_h)
                auto_scroll = False
            elif key == curses.KEY_NPAGE:
                scroll_pos += log_h
                if scroll_pos >= max(0, len(log_lines) - log_h):
                    auto_scroll = True
            elif key == ord('f') or key == ord('F'):
                auto_scroll = True
            
        stdscr.erase()
        
        # Render SMI
        for i in range(min(smi_lines, len(smi_text))):
            try:
                stdscr.addstr(i, 0, smi_text[i][:max_x-1])
            except curses.error:
                pass
            
        if smi_lines < max_y:
            try:
                stdscr.addstr(smi_lines, 0, "-" * (max_x-1), curses.A_REVERSE)
            except curses.error:
                pass
        
        # Determine scroll position
        if auto_scroll:
            scroll_pos = max(0, len(log_lines) - log_h)
        else:
            scroll_pos = min(scroll_pos, max(0, len(log_lines) - log_h))
            
        # Render Log
        for i in range(log_h):
            idx = scroll_pos + i
            if idx < len(log_lines):
                line = log_lines[idx]
                
                # Determine block color by scanning backwards (up to 500 lines)
                block_color = curses.color_pair(0)
                is_thought = False
                
                for j in range(idx, max(-1, idx - 500), -1):
                    check_line = log_lines[j]
                    if check_line.startswith("### USER") or check_line.startswith("USER:"):
                        block_color = curses.color_pair(1)
                        break
                    elif check_line.startswith("### ASSISTANT") or check_line.startswith("ASSISTANT:") or check_line.startswith("### SYSTEM"):
                        block_color = curses.color_pair(2)
                        break
                    elif check_line.startswith("====================") or check_line.startswith("--------------------------------------------------------------------------------"):
                        break # Reset to default if we cross a separator
                
                # Check if we're inside a THOUGHT block
                for j in range(idx, max(-1, idx - 500), -1):
                    check_line = log_lines[j]
                    if "<think>" in check_line or "[THOUGHT]" in check_line:
                        is_thought = True
                        if "</think>" in check_line or "[/THOUGHT]" in check_line:
                            if max(check_line.rfind("</think>"), check_line.rfind("[/THOUGHT]")) > max(check_line.rfind("<think>"), check_line.rfind("[THOUGHT]")):
                                is_thought = False
                        break
                    elif "</think>" in check_line or "[/THOUGHT]" in check_line:
                        is_thought = False
                        break
                    elif check_line.startswith("====================") or check_line.startswith("--------------------------------------------------------------------------------"):
                        is_thought = False
                        break

                # Apply base block color
                color = curses.color_pair(4) if is_thought else block_color
                
                # Override color for specific marker lines
                if line.startswith("### USER") or line.startswith("USER:") or line.startswith("### ASSISTANT") or line.startswith("ASSISTANT:") or line.startswith("### SYSTEM"):
                    color = color | curses.A_BOLD
                elif line.startswith("====================") or line.startswith("--------------------------------------------------------------------------------"):
                    color = curses.color_pair(3) | curses.A_BOLD
                elif "<think>" in line or "</think>" in line or "[THOUGHT]" in line or "[/THOUGHT]" in line:
                    color = curses.color_pair(4) | curses.A_BOLD
                
                try:
                    stdscr.addstr(smi_lines + 1 + i, 0, line[:max_x-1], color)
                except curses.error:
                    pass
        
        # Render Status Bar
        if max_y > 0:
            status_text = " [LIVE] (Up/Dn/PgUp/PgDn: Scroll | F: Follow | Q/Ctrl+C: Quit) " if auto_scroll else f" [PAUSED] (Line {scroll_pos}/{len(log_lines)}) (Press F to follow) "
            status_line = status_text.ljust(max_x-1)
            try:
                stdscr.addstr(max_y-1, 0, status_line[:max_x-1], curses.A_REVERSE)
            except curses.error:
                pass
        
        stdscr.refresh()
        time.sleep(0.05)

if __name__ == "__main__":
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
