#!/usr/bin/env python3
import curses
import subprocess
import time
import threading
import os
import pathlib
from collections import deque
import urllib.request
import json
import re

# Resolve paths relative to this script so the tool works for any user/install location
SCRIPTS_DIR = pathlib.Path(__file__).resolve().parent
HEADER_FILE = SCRIPTS_DIR / "header.txt"
OLLAMA_CONFIG_FILE = SCRIPTS_DIR / "ollama.conf"
READABLE_LOG = str(SCRIPTS_DIR.parent / "ollama_readable.log")

SETTINGS = {
    "gpu_tool": "auto",
    "show_gpu": True,
    "show_cpu": True,
    "show_log": True,
    "show_hints": True,
    "ollama_host": "http://127.0.0.1:11435"
}

def load_settings():
    if OLLAMA_CONFIG_FILE.exists():
        for raw in OLLAMA_CONFIG_FILE.read_text().splitlines():
            line = raw.strip()
            if not line or "=" not in line:
                continue
            try:
                key, val = line.split("=", 1)
                key = key.strip()
                val = val.strip().strip('"')
                if key == "OLLAMA_HOST":
                    if val:
                        if not val.startswith("http://") and not val.startswith("https://"):
                            val = "http://" + val
                        SETTINGS["ollama_host"] = val.rstrip("/")
                elif key == "GPU_TOOL":
                    SETTINGS["gpu_tool"] = val
                elif key in ["SHOW_GPU", "SHOW_CPU", "SHOW_LOG", "SHOW_HINTS"]:
                    SETTINGS[key.lower()] = val.lower() == "true"
            except ValueError:
                continue

def save_setting(key, value):
    lines = []
    found = False
    key_upper = key.upper()
    if key == "ollama_host": key_upper = "OLLAMA_HOST"
    
    if OLLAMA_CONFIG_FILE.exists():
        lines = OLLAMA_CONFIG_FILE.read_text().splitlines()
    
    new_lines = []
    for line in lines:
        if line.strip().startswith(key_upper + "="):
            new_lines.append(f"{key_upper}={value}")
            found = True
        else:
            new_lines.append(line)
    
    if not found:
        new_lines.append(f"{key_upper}={value}")
    
    OLLAMA_CONFIG_FILE.write_text("\n".join(new_lines) + "\n")
    SETTINGS[key] = value

load_settings()
OLLAMA_API_URL = SETTINGS["ollama_host"]

def get_cpu_usage():
    try:
        with open('/proc/stat', 'r') as f:
            line1 = f.readline()
        time.sleep(0.05)
        with open('/proc/stat', 'r') as f:
            line2 = f.readline()
        
        def parse_stat(line):
            parts = line.split()
            idle = float(parts[4])
            total = sum(float(x) for x in parts[1:])
            return idle, total
        
        idle1, total1 = parse_stat(line1)
        idle2, total2 = parse_stat(line2)
        
        diff_idle = idle2 - idle1
        diff_total = total2 - total1
        
        if diff_total == 0:
            return 0.0
        return max(0.0, min(100.0, (1.0 - diff_idle / diff_total) * 100.0))
    except Exception:
        return 0.0

def get_ram_usage():
    try:
        with open('/proc/meminfo', 'r') as f:
            lines = f.readlines()
        mem_info = {}
        for line in lines:
            parts = line.split(':')
            if len(parts) == 2:
                mem_info[parts[0].strip()] = int(parts[1].strip().split()[0])
        
        total = mem_info.get('MemTotal', 0)
        available = mem_info.get('MemAvailable', mem_info.get('MemFree', 0))
        
        if total > 0:
            total_gb = total / (1024 * 1024)
            available_gb = available / (1024 * 1024)
            used_gb = total_gb - available_gb
            return total_gb, available_gb, used_gb
    except Exception:
        pass
    return 0.0, 0.0, 0.0

def get_cpu_temp():
    try:
        paths = [
            '/sys/class/thermal/thermal_zone0/temp',
            '/sys/class/thermal/thermal_zone1/temp',
            '/sys/class/hwmon/hwmon0/temp1_input',
            '/sys/class/hwmon/hwmon1/temp1_input',
        ]
        for p in paths:
            if os.path.exists(p):
                with open(p, 'r') as f:
                    return float(f.read().strip()) / 1000.0
    except Exception:
        pass
    return 0.0

def get_system_temps():
    temps = []
    # This will be used as the overall system 'cpu_temp' for indicators
    max_sys_temp = 0.0
    try:
        output = subprocess.check_output(["sensors", "-j"], text=True, errors="replace", stderr=subprocess.DEVNULL)
        import json
        data = json.loads(output)
        for adapter, sensors_dict in data.items():
            if adapter == "Adapter": continue
            for sensor_name, readings in sensors_dict.items():
                if isinstance(readings, dict):
                    for k, v in readings.items():
                        if k.endswith("_input") and "temp" in k:
                            temp_val = float(v)
                            # Track max for overall system status
                            max_sys_temp = max(max_sys_temp, temp_val)
                            
                            short_adapter = adapter.split('-')[0].upper()
                            # Mapping: original -> short
                            replacements = {
                                "AMDGPU": "GPU",
                                "K10TEMP": "K10",
                                "CORETEMP": "CPU",
                                "NVME": "SSD",
                                "ACPI": "SYS",
                                "R8169": "NET"
                            }
                            for old, new in replacements.items():
                                short_adapter = short_adapter.replace(old, new)
                            
                            # Hide primary sensors from the "System temps" list to keep it clean
                            if short_adapter in ["CPU", "K10", "GPU"]:
                                continue

                            # Simplify sensor: only keep numeric suffix if present
                            short_sensor = sensor_name.replace("temp", "").replace("Sensor", "").replace("Composite", "").upper()
                            numeric_part = "".join([c for c in short_sensor if c.isdigit()])

                            if numeric_part:
                                temps.append(f"{short_adapter}_{numeric_part}:{temp_val:.0f}°C")
                            else:
                                temps.append(f"{short_adapter}:{temp_val:.0f}°C")
    except Exception:
        pass
    
    if max_sys_temp == 0.0:
        max_sys_temp = get_cpu_temp()
        
    return max_sys_temp, temps

GPU_TOOLS = ["auto", "nvidia-smi", "amd-smi", "rocm-smi", "none"]

def detect_gpu_tool():
    if SETTINGS["gpu_tool"] != "auto":
        return SETTINGS["gpu_tool"]
    for tool in ["nvidia-smi", "amd-smi", "rocm-smi"]:
        if subprocess.call(["which", tool], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) == 0:
            return tool
    return "none"

# Fallback to installed location if running from dev and log not found

log_lines = deque(maxlen=100000)
log_lines_total_count = 0
smi_text = ["Loading GPU status..."]
error_messages = {}
log_lock = threading.Lock()
smi_lock = threading.Lock()
error_lock = threading.Lock()
log_ready = threading.Event()
smi_ready = threading.Event()
_tail_proc = None  # module-level reference so we can terminate on exit
last_log_update = time.time()
ANSI_ESCAPE_RE = re.compile(r"\x1b(?:\[[0-?]*[ -/]*[@-~]|\][^\x07]*(?:\x07|\x1b\\)|[ -/]*[@-~])")
LITERAL_ANSI_ESCAPE_RE = re.compile(r"\\033(?:\[[0-?]*[ -/]*[@-~]|\][^\x07]*(?:\x07|\\033\\)|[ -/]*[@-~])")
CONTROL_CHARS_RE = re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]")
ROLE_MARKERS = {
    "### USER": 1,
    "### ASSISTANT": 2,
    "### SYSTEM": 2,
}
ANSI_TOKEN_RE = re.compile(r"(?:\x1b|\\033)\[([0-9;]*)m")
ansi_color_pairs = {}
next_ansi_color_pair = 10
SCROLL_LINE_STEP = 3
STARTUP_LOGO_SECONDS = 2.0

def sanitize_render_text(text):
    text = ANSI_ESCAPE_RE.sub("", text)
    text = LITERAL_ANSI_ESCAPE_RE.sub("", text)
    text = text.replace("\r", "")
    text = text.replace("\t", "    ")
    text = text.replace("<|im_start|>system", "### SYSTEM")
    text = text.replace("<|im_start|>user", "### USER")
    text = text.replace("<|im_start|>assistant", "### ASSISTANT")
    text = text.replace("<|im_start|>", "")
    text = text.replace("<|im_end|>", "")
    text = text.replace("<|endoftext|>", "")
    return CONTROL_CHARS_RE.sub("", text)

def wrap_render_line(line, width):
    line = sanitize_render_text(line)
    if width <= 1:
        return [line[:1]]
    if not line:
        return [""]
    return [line[i:i + width] for i in range(0, len(line), width)]

def role_color_pair_for_line(line):
    for marker, color_pair in ROLE_MARKERS.items():
        if line.startswith(marker):
            return color_pair
    return None

def is_role_marker_line(line):
    return role_color_pair_for_line(line) is not None

def is_separator_line(line):
    return line.startswith("====================") or line.startswith("--------------------------------------------------------------------------------")

def line_opens_thought(line):
    return "<think>" in line or "[THOUGHT]" in line

def line_closes_thought(line):
    return "</think>" in line or "[/THOUGHT]" in line

def line_is_in_thought(source_idx, log_snapshot):
    for j in range(source_idx, max(-1, source_idx - 500), -1):
        check_line = sanitize_render_text(log_snapshot[j])
        if line_opens_thought(check_line):
            if line_closes_thought(check_line):
                return max(check_line.rfind("</think>"), check_line.rfind("[/THOUGHT]")) < max(
                    check_line.rfind("<think>"), check_line.rfind("[THOUGHT]")
                )
            return True
        if line_closes_thought(check_line) or is_separator_line(check_line):
            return False
    return False

def render_attr_for_log_line(source_idx, line, log_snapshot, color_pair=None):
    if color_pair is None:
        color_pair = curses.color_pair

    role_color_pair = role_color_pair_for_line(line)
    if role_color_pair is not None:
        return color_pair(role_color_pair) | curses.A_BOLD
    if is_separator_line(line):
        return color_pair(3) | curses.A_BOLD
    if line_opens_thought(line) or line_closes_thought(line):
        return color_pair(4) | curses.A_BOLD
    if line_is_in_thought(source_idx, log_snapshot):
        return color_pair(4)
    return color_pair(0)

def visible_ansi_text(line):
    return ANSI_TOKEN_RE.sub("", line)

def ansi_attr(fg_color, bold):
    global next_ansi_color_pair

    attr = curses.A_BOLD if bold else curses.A_NORMAL
    if fg_color is None:
        return attr

    if not curses.has_colors() or fg_color >= curses.COLORS:
        return attr

    pair = ansi_color_pairs.get(fg_color)
    if pair is None:
        pair = next_ansi_color_pair
        next_ansi_color_pair += 1
        try:
            curses.init_pair(pair, fg_color, -1)
        except curses.error:
            return attr
        ansi_color_pairs[fg_color] = pair

    return attr | curses.color_pair(pair)

def render_ansi_line(stdscr, y, x, line, max_width):
    fg_color = None
    bold = False
    pos = 0
    draw_x = x

    for match in ANSI_TOKEN_RE.finditer(line):
        chunk = line[pos:match.start()]
        if chunk and draw_x < max_width:
            try:
                stdscr.addstr(y, draw_x, chunk[:max_width - draw_x], ansi_attr(fg_color, bold))
            except curses.error:
                pass
            draw_x += len(chunk)

        codes = [int(code) for code in match.group(1).split(";") if code.isdigit()]
        i = 0
        while i < len(codes):
            code = codes[i]
            if code == 0:
                fg_color = None
                bold = False
            elif code == 1:
                bold = True
            elif code == 38 and i + 2 < len(codes) and codes[i + 1] == 5:
                fg_color = codes[i + 2]
                i += 2
            elif 30 <= code <= 37:
                fg_color = code - 30
            elif 90 <= code <= 97:
                fg_color = code - 90 + 8
            elif code == 39:
                fg_color = None
            i += 1

        pos = match.end()

    chunk = line[pos:]
    if chunk and draw_x < max_width:
        try:
            stdscr.addstr(y, draw_x, chunk[:max_width - draw_x], ansi_attr(fg_color, bold))
        except curses.error:
            pass

def build_visible_log_lines(width):
    with log_lock:
        log_snapshot = list(log_lines)
        total_count = log_lines_total_count
    visible = []
    for idx, line in enumerate(log_snapshot):
        for segment in wrap_render_line(line, width):
            visible.append((idx, segment))
    return visible, log_snapshot, total_count

def collect_input(stdscr):
    keys = []
    while True:
        key = stdscr.getch()
        if key == -1:
            return keys
        keys.append(key)

def apply_input(keys, scroll_pos, auto_scroll, log_line_count, log_h):
    max_scroll = max(0, log_line_count - log_h)
    changed = False

    if keys:
        for key in keys:
            if key == curses.KEY_UP:
                scroll_pos -= SCROLL_LINE_STEP
                auto_scroll = False
                changed = True
            elif key == curses.KEY_DOWN:
                scroll_pos += SCROLL_LINE_STEP
                changed = True
                if scroll_pos >= max_scroll:
                    scroll_pos = max_scroll
                    auto_scroll = True
                else:
                    auto_scroll = False
            elif key == curses.KEY_PPAGE:
                scroll_pos -= log_h
                auto_scroll = False
                changed = True
            elif key == curses.KEY_NPAGE:
                scroll_pos += log_h
                changed = True
                if scroll_pos >= max_scroll:
                    scroll_pos = max_scroll
                    auto_scroll = True
                else:
                    auto_scroll = False
            elif key == ord('f') or key == ord('F'):
                auto_scroll = not auto_scroll
                changed = True
            elif key == ord('g') or key == ord('G'):
                save_setting("show_gpu", not SETTINGS["show_gpu"])
                changed = True
            elif key == ord('c') or key == ord('C'):
                save_setting("show_cpu", not SETTINGS["show_cpu"])
                changed = True
            elif key == ord('l') or key == ord('L'):
                save_setting("show_log", not SETTINGS["show_log"])
                changed = True
            elif key == ord('h') or key == ord('H'):
                save_setting("show_hints", not SETTINGS["show_hints"])
                changed = True
            elif key == ord('t') or key == ord('T'):
                toggle_gpu_tool()
                changed = True
            elif key == curses.KEY_MOUSE:
                try:
                    _, _, _, _, bstate = curses.getmouse()
                    if bstate & 0x10000: # curses.BUTTON4_PRESSED/SCROLL_UP
                        scroll_pos -= SCROLL_LINE_STEP
                        auto_scroll = False
                        changed = True
                    elif bstate & 0x200000: # curses.BUTTON5_PRESSED/SCROLL_DOWN
                        scroll_pos += SCROLL_LINE_STEP
                        changed = True
                        if scroll_pos >= max_scroll:
                            scroll_pos = max_scroll
                            auto_scroll = True
                        else:
                            auto_scroll = False
                except curses.error:
                    pass

    if auto_scroll:
        scroll_pos = max_scroll
    else:
        scroll_pos = min(max(0, scroll_pos), max_scroll)

    return scroll_pos, auto_scroll, changed

def set_error(key, message):
    with error_lock:
        if message:
            error_messages[key] = sanitize_render_text(message)
        else:
            error_messages.pop(key, None)

def get_val_color(val, t1, t2, t3, t4, color_pair_func=curses.color_pair):
    if val < t1:
        return color_pair_func(5)  # Blue (Cold)
    elif val < t2:
        return color_pair_func(2)  # Green (Optimal)
    elif val < t3:
        return color_pair_func(3)  # Yellow (Warm)
    elif val < t4:
        return color_pair_func(6)  # Orange (Hot-Warm)
    else:
        return color_pair_func(11) # Red (Hot)

def get_temp_color(temp, color_pair_func=curses.color_pair):
    return get_val_color(temp, 35, 55, 70, 85, color_pair_func)

def toggle_gpu_tool():
    current = SETTINGS["gpu_tool"]
    try:
        idx = (GPU_TOOLS.index(current) + 1) % len(GPU_TOOLS)
    except ValueError:
        idx = 0
    new_tool = GPU_TOOLS[idx]
    save_setting("gpu_tool", new_tool)
    return new_tool

def set_smi_text(lines, cpu_temp=0.0):
    global smi_text, latest_cpu_temp
    with smi_lock:
        smi_text = lines
        latest_cpu_temp = cpu_temp
    smi_ready.set()

def get_smi_snapshot():
    with smi_lock:
        return list(smi_text), latest_cpu_temp

def poll_smi():
    while True:
        # GPU detection and polling
        tool = detect_gpu_tool()
        hw_lines = []
        if tool != "none":
            try:
                # Try standard execution first
                output = subprocess.check_output([tool], text=True, errors="replace", stderr=subprocess.STDOUT)
                
                # Check for common permission error message regarding process names (e.g. amd-smi)
                if "Elevated permissions" in output or "Permission denied" in output:
                    try:
                        # Try sudo -n (non-interactive, fails if password required)
                        sudo_output = subprocess.check_output(["sudo", "-n", tool], text=True, errors="replace", stderr=subprocess.STDOUT)
                        output = sudo_output
                    except Exception:
                        # If sudo failed, add a helpful tip to the output
                        if "Elevated permissions" in output:
                            output += "\n\033[93mTip: Run 'sudo usermod -a -G render,video $USER' and restart session to see process names.\033[0m"
                
                hw_lines = output.splitlines()
            except Exception:
                hw_lines = [f"\033[31m({tool} unavailable)\033[0m"]
        else:
            hw_lines = ["\033[90m(no GPU tool detected)\033[0m"]

        # CPU load and temp
        cpu_load = get_cpu_usage()
        cpu_temp, sys_temps = get_system_temps()
        ram_total, ram_avail, ram_used = get_ram_usage()
        
        # Parallel sessions allowed
        num_parallel = get_ollama_num_parallel()

        # GPU/CPU split from 'ollama ps'
        ps_info = parse_ollama_ps()

        # Model details from /api/ps
        model_lines = []
        try:
            req = urllib.request.Request(f"{OLLAMA_API_URL}/api/ps", method="GET")
            with urllib.request.urlopen(req, timeout=1) as response:
                data = json.loads(response.read().decode())
                models = data.get("models", [])
                if models:
                    for m in models:
                        name = m.get("name", "unknown")
                        ctx = m.get("context_length", 0)
                        size = m.get("size", 0)
                        size_vram = m.get("size_vram", 0)

                        # GPU/CPU split: prefer 'ollama ps', fall back to size_vram ratio
                        processor = ps_info.get(name, "")
                        if not processor and size > 0:
                            gpu_pct = int(round(size_vram / size * 100))
                            cpu_pct = 100 - gpu_pct
                            processor = f"{gpu_pct}% GPU / {cpu_pct}% CPU"

                        size_str = f"{size / (1024**3):.1f} GB" if size > 0 else "? GB"
                        
                        param_details_str = _get_model_params(name)

                        model_lines.append(f"  \033[1;32m{name}\033[0m ({size_str} | {processor or 'unknown'})")
                        model_lines.append(f"    \033[34m└\033[0m ctx:{ctx}{param_details_str}")
                else:
                    model_lines = ["  \033[90m(no active models)\033[0m"]
                set_error("ollama", None)
        except Exception:
            model_lines = ["  \033[31m(could not reach Ollama API)\033[0m"]
            set_error("ollama", "Ollama is not reachable. Run 'ollama serve' to start it.")

        full_smi_lines = []
        header = f"\033[1;36m=== OLLAMA  parallel:{num_parallel}  tool:{tool} ===\033[0m"
        full_smi_lines.append(header)
        full_smi_lines.extend(model_lines)
        full_smi_lines.append("")
        
        if SETTINGS["show_cpu"]:
            cpu_pct = f"{cpu_load:2.0f}%"
            temp_str = f"{cpu_temp:2.0f}°C"
            cpu_line = f"CPU:{cpu_pct} {temp_str}"
            
            if ram_total > 0:
                cpu_line += f" | RAM:{ram_avail:.0f}/{ram_total:.0f}G"
            
            if sys_temps:
                cpu_line += " | " + " ".join(sys_temps)
            full_smi_lines.append(cpu_line)
            full_smi_lines.append("")
            
        if SETTINGS["show_gpu"]:
            full_smi_lines.extend(hw_lines)
            
        set_smi_text(full_smi_lines, cpu_temp=cpu_temp)
        time.sleep(0.5)

def get_error_lines(width):
    with error_lock:
        messages = list(error_messages.values())
    if not messages:
        return []
    text = " | ".join(messages)
    return wrap_render_line(text, width)

def tail_log():
    global _tail_proc, last_log_update
    import fcntl
    try:
        _tail_proc = subprocess.Popen(
            ['tail', '-f', '-n', '2000', READABLE_LOG],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        p = _tail_proc
        log_ready.set()
        fd = p.stdout.fileno()
        fl = fcntl.fcntl(fd, fcntl.F_GETFL)
        fcntl.fcntl(fd, fcntl.F_SETFL, fl | os.O_NONBLOCK)

        current_line = ""
        while True:
            try:
                chunk_bytes = p.stdout.read(4096)
            except BlockingIOError:
                chunk_bytes = None

            if chunk_bytes:
                last_log_update = time.time()
                set_error("log", None)
                try:
                    text = chunk_bytes.decode('utf-8', errors='replace')
                except Exception:
                    text = ""
                
                parts = text.split('\n')
                with log_lock:
                    global log_lines_total_count
                    if len(parts) == 1:
                        current_line += parts[0]
                        if log_lines:
                            log_lines[-1] = current_line.replace('\t', '    ')
                        else:
                            log_lines.append(current_line.replace('\t', '    '))
                            log_lines_total_count += 1
                    else:
                        current_line += parts[0]
                        if log_lines:
                            log_lines[-1] = current_line.replace('\t', '    ')
                        else:
                            log_lines.append(current_line.replace('\t', '    '))
                            log_lines_total_count += 1

                        for part in parts[1:-1]:
                            log_lines.append(part.replace('\t', '    '))
                            log_lines_total_count += 1

                        current_line = parts[-1]
                        log_lines.append(current_line.replace('\t', '    '))
                        log_lines_total_count += 1
            else:
                if p.poll() is not None:
                    error = ""
                    if p.stderr is not None:
                        try:
                            error = p.stderr.read().decode('utf-8', errors='replace').strip()
                        except Exception:
                            error = ""
                    set_error("log", error or "Log tail stopped")
                    return
                time.sleep(0.05)
    except Exception as e:
        set_error("log", f"Log tail error: {e}")
        log_ready.set()

def get_ollama_num_parallel():
    """Return OLLAMA_NUM_PARALLEL from the current env or the running ollama process env."""
    val = os.environ.get("OLLAMA_NUM_PARALLEL")
    if val:
        return val
    try:
        pid_out = subprocess.check_output(
            ['pgrep', '-x', 'ollama'],
            text=True,
            timeout=2,
            stderr=subprocess.DEVNULL,
        ).strip()
        if pid_out:
            pid = pid_out.splitlines()[0].strip()
            with open(f'/proc/{pid}/environ', 'rb') as f:
                env_data = f.read()
            for entry in env_data.split(b'\x00'):
                if entry.startswith(b'OLLAMA_NUM_PARALLEL='):
                    return entry.split(b'=', 1)[1].decode()
    except Exception:
        pass
    return "auto"

def parse_ollama_ps():
    """Run 'ollama ps' and return a dict of model_name -> processor_string."""
    result = {}
    try:
        ps_output = subprocess.check_output(
            ['ollama', 'ps'],
            text=True,
            errors="replace",
            timeout=3,
            stderr=subprocess.DEVNULL,
        )
        ps_lines = ps_output.strip().splitlines()
        if len(ps_lines) < 2:
            return result
        header_line = ps_lines[0].upper()
        proc_col = header_line.find("PROCESSOR")
        until_col = header_line.find("UNTIL")
        if proc_col < 0:
            return result
        for row in ps_lines[1:]:
            if not row.strip():
                continue
            name_field = row[:proc_col].strip()
            name = name_field.split()[0] if name_field else ""
            if until_col > proc_col:
                processor = row[proc_col:until_col].strip()
            else:
                processor = row[proc_col:].strip()
            if name:
                result[name] = processor
    except Exception:
        pass
    return result

def _get_model_params(model_name):
    """Fetch model parameters from /api/show and return a formatted string."""
    params_of_interest = [
        "temperature", "num_batch", "num_gqa",
        "top_k", "top_p", "tfs_z"
    ]
    try:
        req_body = json.dumps({"name": model_name}).encode()
        req = urllib.request.Request(f"{OLLAMA_API_URL}/api/show", data=req_body, method="POST")
        req.add_header('Content-Type', 'application/json')
        with urllib.request.urlopen(req, timeout=1) as response:
            data = json.loads(response.read().decode())
            param_str = data.get("parameters", "")
            if not param_str:
                return ""
            
            params = {}
            for line in param_str.splitlines():
                parts = line.strip().split(None, 1)
                if len(parts) == 2:
                    params[parts[0]] = parts[1]

            param_list = []
            for p in params_of_interest:
                if p in params:
                    # Shorten names for display
                    short_name = p.replace("temperature", "temp").replace("num_", "")
                    param_list.append(f"{short_name}:{params[p]}")
            
            return " | " + " ".join(param_list)

    except Exception:
        return ""

def main(stdscr):
    # Load ASCII Header
    try:
        with open(HEADER_FILE, "r") as f:
            header_lines = f.read().splitlines()
    except FileNotFoundError:
        header_lines = ["WATCH OLLAMA", "Monitoring, Benchmarking, & Management Suite"]
    
    header = header_lines + ["", "Welcome to watch-ollama. Press 'q' to quit."]
    
    curses.curs_set(0)
    stdscr.nodelay(1)
    stdscr.keypad(True)
    stdscr.timeout(16)
    
    # Enable mouse events for scrolling
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
    # Some terminals need this to enable mouse reporting
    print("\033[?1003h", end="") 
    
    # Setup Colors
    curses.start_color()
    curses.use_default_colors()
    
    curses.init_pair(1, curses.COLOR_CYAN, -1)     # USER block
    curses.init_pair(2, curses.COLOR_GREEN, -1)    # ASSISTANT/OK
    curses.init_pair(3, curses.COLOR_YELLOW, -1)   # WARNING/WARN
    curses.init_pair(4, curses.COLOR_MAGENTA, -1)  # THOUGHT block
    curses.init_pair(11, curses.COLOR_RED, -1)     # DANGER/HOT
    curses.init_pair(5, curses.COLOR_BLUE, -1)      # COLD
    
    # Orange (if supported by terminal)
    if curses.COLORS >= 256:
        curses.init_pair(6, 208, -1) 
    else:
        curses.init_pair(6, curses.COLOR_YELLOW, -1) # Fallback to Yellow
    
    # Ensure standard color pairs are usable if missing
    if curses.COLORS >= 8:
        pass # Everything is mapped. 1, 2, 3, 11 are the key ones used.
    
    t_log = threading.Thread(target=tail_log, daemon=True)
    t_log.start()
    
    t_smi = threading.Thread(target=poll_smi, daemon=True)
    t_smi.start()

    startup_until = time.time() + STARTUP_LOGO_SECONDS
    while time.time() < startup_until:
        max_y, max_x = stdscr.getmaxyx()
        stdscr.erase()

        start_y = max(0, (max_y - len(header)) // 2)
        for i, line in enumerate(header):
            y = start_y + i
            if y >= max_y:
                break
            visible_line = visible_ansi_text(line)
            x = max(0, (max_x - len(visible_line)) // 2)
            render_ansi_line(stdscr, y, x, line, max_x - 1)

        stdscr.refresh()
        key = stdscr.getch()
        if key == 3 or key == ord('q') or key == ord('Q') or key == 27:
            return
        time.sleep(0.05)

    scroll_pos = 0
    auto_scroll = True
    reserved_smi_lines_by_height = {}

    while True:
        max_y, max_x = stdscr.getmaxyx()
        smi_snapshot, cpu_temp = get_smi_snapshot()

        # Keep the top telemetry panel from jumping when Ollama briefly changes
        # model/prompt rows. Reset the reservation only when the terminal height changes.
        max_smi_lines = max(1, max_y // 2)
        observed_smi_lines = len(smi_snapshot) if smi_snapshot else 15
        reserved_smi_lines = reserved_smi_lines_by_height.get(max_y, 0)
        smi_lines = min(max_smi_lines, max(reserved_smi_lines, observed_smi_lines))
        reserved_smi_lines_by_height[max_y] = smi_lines
            
        render_width = max(1, max_x - 1)
        active_errors = get_error_lines(render_width)
        error_h = min(2, len(active_errors))

        log_h = max_y - smi_lines - error_h - 2
        if log_h < 1:
            log_h = 1 # Prevent crash on tiny terminal

        visible_log_lines, log_snapshot, total_count = build_visible_log_lines(render_width)

        # Drain all queued keys each frame so held scroll keys do not create a
        # backlog that blocks a direction change.
        keys = collect_input(stdscr)
        if any(key == 3 or key == ord('q') or key == ord('Q') or key == 27 for key in keys):
            break
        scroll_pos, auto_scroll, input_changed = apply_input(
            keys, scroll_pos, auto_scroll, len(visible_log_lines), log_h
        )
            
        stdscr.erase()
        
        # Render SMI
        for i in range(smi_lines):
            line = smi_snapshot[i] if i < len(smi_snapshot) else ""
            try:
                if "CPU:" in line and ("RAM:" in line or "°C" in line):
                    # Robust parsing for the telemetry oneliner
                    # Format: CPU:4.1% 43.1°C | RAM:15/32G | adapter:58°C ...
                    parts = line.split(" | ")
                    
                    curr_x = 0
                    def safe_addstr(text, attr=0):
                        nonlocal curr_x
                        if curr_x >= max_x - 1: return False
                        safe_text = text[:max_x - 1 - curr_x]
                        if not safe_text: return False
                        try:
                            stdscr.addstr(i, curr_x, safe_text, attr)
                        except curses.error:
                            pass
                        curr_x += len(safe_text)
                        return True
                    
                    for idx, part in enumerate(parts):
                        if idx > 0:
                            if not safe_addstr(" | "): break
                        
                        if part.startswith("CPU:"):
                            if not safe_addstr("CPU", curses.A_BOLD): break
                            sub = part[4:].strip().split()
                            if not sub: continue
                            # Load %
                            val_str = sub[0]
                            try:
                                val = float(val_str.replace("%", ""))
                                if not safe_addstr(" " + val_str, get_val_color(val, 25, 50, 75, 90)): break
                            except ValueError:
                                if not safe_addstr(" " + val_str): break
                            # Temp
                            if len(sub) > 1:
                                temp_str = sub[1]
                                try:
                                    t_val = float(temp_str.replace("°C", ""))
                                    t_color = get_temp_color(t_val)
                                    if not safe_addstr(" "): break
                                    if not safe_addstr(" 🌡 ", curses.A_REVERSE | t_color): break
                                    if not safe_addstr(" " + temp_str, t_color): break
                                except ValueError:
                                    if not safe_addstr(" " + temp_str): break
                        elif part.startswith("RAM:"):
                            if not safe_addstr("RAM:", curses.A_BOLD): break
                            r_val_str = part[4:].strip()
                            if "/" in r_val_str:
                                try:
                                    v1, v2 = r_val_str.split('/')
                                    u_pct = (1.0 - float(v1.replace("G", "").replace("M", "")) / float(v2.replace("G", "").replace("M", ""))) * 100
                                    if not safe_addstr(" " + r_val_str, get_val_color(u_pct, 25, 50, 75, 90)): break
                                except (ValueError, ZeroDivisionError):
                                    if not safe_addstr(" " + r_val_str): break
                        else:
                            # System temps
                            s_parts = part.split()
                            for s_idx, s_p in enumerate(s_parts):
                                if s_idx > 0:
                                    if not safe_addstr(" "): break
                                if ":" in s_p:
                                    try:
                                        name, t_val_str = s_p.split(":")
                                        if not safe_addstr(name + ":", curses.A_BOLD): break
                                        t_val = float(t_val_str.replace("°C", ""))
                                        t_color = get_temp_color(t_val)
                                        if not safe_addstr(t_val_str, t_color): break
                                    except ValueError:
                                        if not safe_addstr(s_p): break
                                else:
                                    if not safe_addstr(s_p): break
                else:
                    render_ansi_line(stdscr, i, 0, line, max_x - 1)
            except (curses.error, ValueError, IndexError):
                try:
                    render_ansi_line(stdscr, i, 0, line, max_x - 1)
                except curses.error:
                    pass
            
        if smi_lines < max_y:
            try:
                stdscr.addstr(smi_lines, 0, "-" * (max_x-1), curses.A_REVERSE)
            except curses.error:
                pass
        
        # Render Log
        if SETTINGS["show_log"]:
            for i in range(log_h):
                idx = scroll_pos + i
                if idx < len(visible_log_lines):
                    source_idx, line = visible_log_lines[idx]
                    color = render_attr_for_log_line(source_idx, line, log_snapshot)
                    
                    try:
                        stdscr.addstr(smi_lines + 1 + i, 0, line[:render_width], color)
                    except curses.error:
                        pass
        
        # Render Error Section
        error_start = max_y - 1 - error_h
        for i in range(error_h):
            y = error_start + i
            if y < 0:
                continue
            error_line = (" " + active_errors[i]).ljust(render_width)
            try:
                stdscr.addstr(y, 0, error_line[:render_width], curses.color_pair(3) | curses.A_BOLD)
            except curses.error:
                pass

        # Render Status Bar
        if max_y > 0:
            follow_txt = "FOLLOWING" if auto_scroll else "PAUSED"
            follow_hint = "Pause" if auto_scroll else "Follow"
            hints = f" (G:GPU C:CPU L:Log H:Hint T:Tool | F:{follow_hint} | Q:Quit) " if SETTINGS["show_hints"] else f" ({follow_txt}) "
            status_text = f" [{follow_txt}] (Line {scroll_pos}/{len(visible_log_lines)}){hints}"
            status_line = status_text.ljust(max_x-1)
            try:
                stdscr.addstr(max_y-1, 0, status_line[:max_x-1], curses.A_REVERSE)
                
                # Overlay status markers if space permits
                status_pos = max_x - 22
                if status_pos > len(status_text) + 2:
                    temp_color = get_temp_color(cpu_temp)
                    # Merge thermometer and color: symbol + color-based background
                    stdscr.addstr(max_y-1, status_pos, " 🌡 ", curses.A_REVERSE | temp_color)
                    
                    if active_errors:
                        stdscr.addstr(max_y-1, status_pos + 4, " ⚠️ ", curses.color_pair(11) | curses.A_REVERSE)
                    
                    log_active = (time.time() - last_log_update < 2.0)
                    log_text = "output" if log_active else "idle"
                    log_col = curses.color_pair(2) if log_active else curses.color_pair(3)
                    stdscr.addstr(max_y-1, status_pos + 9, f" {log_text} ", curses.A_REVERSE | log_col)
            except curses.error:
                pass

            # Update dynamic terminal title with color emojis
            # Scale: Blue < 35, Green < 55, Yellow < 70, Orange < 85, Red >= 85
            if cpu_temp < 35:
                t_mark = "🟦"
            elif cpu_temp < 55:
                t_mark = "🟩"
            elif cpu_temp < 70:
                t_mark = "🟨"
            elif cpu_temp < 85:
                t_mark = "🟧"
            else:
                t_mark = "🟥"
            
            e_part = " ⚠️" if active_errors else ""
            
            log_active = (time.time() - last_log_update < 2.0)
            log_text = " output" if log_active else " idle"
            import sys
            sys.stdout.write(f"\033]0;👀 Watch Ollama {t_mark}{e_part}{log_text}\007")
            sys.stdout.flush()

        stdscr.refresh()
        if not input_changed:
            time.sleep(0.02)
        
        stdscr.refresh()
        if not input_changed:
            time.sleep(0.02)

if __name__ == "__main__":
    import sys
    sys.stdout.write("\033]0;👀 Watch Ollama\007")
    sys.stdout.flush()
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
    finally:
        # Disable mouse reporting
        print("\033[?1003l", end="")
        
        # Clean up the tail subprocess so we don't leave orphaned processes
        if _tail_proc is not None:
            try:
                _tail_proc.terminate()
            except Exception:
                pass
