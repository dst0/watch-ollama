# Resolve paths relative to this script so the tool works for any user/install location
SCRIPTS_DIR = pathlib.Path(__file__).resolve().parent
# Primary installation directory for the tool
INSTALL_DIR = pathlib.Path.home() / ".ollama-watch-tool"

HEADER_FILE = SCRIPTS_DIR / "header.txt"
HEADER_SMALL_FILE = SCRIPTS_DIR / "header_small.txt"
OLLAMA_CONFIG_FILE = SCRIPTS_DIR / "ollama.conf"

# Prioritize config in the tool root, then check scripts/ fallback
if (INSTALL_DIR / "ollama.conf").exists():
    OLLAMA_CONFIG_FILE = INSTALL_DIR / "ollama.conf"
elif not OLLAMA_CONFIG_FILE.exists() and (INSTALL_DIR / "scripts" / "ollama.conf").exists():
    OLLAMA_CONFIG_FILE = INSTALL_DIR / "scripts" / "ollama.conf"

# Primary log location is sibling to 'scripts/' (standard behavior)
READABLE_LOG = str(SCRIPTS_DIR.parent / "ollama_readable.log")
DEBUG_LOG = str(SCRIPTS_DIR.parent / "watch-ollama-debug.log")

# Fallback to installed location if running from dev and logs not found locally
if not os.path.exists(READABLE_LOG) and (INSTALL_DIR / "ollama_readable.log").exists():
    READABLE_LOG = str(INSTALL_DIR / "ollama_readable.log")

if not os.path.exists(DEBUG_LOG) and INSTALL_DIR.exists():
    DEBUG_LOG = str(INSTALL_DIR / "watch-ollama-debug.log")

SETTINGS = {
    "gpu_tool": "auto",
    "show_gpu": True,
    "show_cpu": True,
    "show_log": True,
    "show_hints": True,
    "ollama_host": "http://127.0.0.1:11435"
}

def load_settings():
    if OLLAMA_CONFIG_FILE.exists():
        for raw in OLLAMA_CONFIG_FILE.read_text().splitlines():
            line = raw.strip()
            if not line or "=" not in line:
                continue
            try:
                key, val = line.split("=", 1)
                key = key.strip()
                val = val.strip().strip('"')
                if key == "OLLAMA_HOST":
                    if val:
                        if not val.startswith("http://") and not val.startswith("https://"):
                            val = "http://" + val
                        SETTINGS["ollama_host"] = val.rstrip("/")
                elif key == "GPU_TOOL":
                    SETTINGS["gpu_tool"] = val
                elif key in ["SHOW_GPU", "SHOW_CPU", "SHOW_LOG", "SHOW_HINTS"]:
                    SETTINGS[key.lower()] = val.lower() == "true"
            except ValueError:
                continue

def save_setting(key, value):
    lines = []
    found = False
    key_upper = key.upper()
    if key == "ollama_host": key_upper = "OLLAMA_HOST"
    
    if OLLAMA_CONFIG_FILE.exists():
        lines = OLLAMA_CONFIG_FILE.read_text().splitlines()
    
    new_lines = []
    for line in lines:
        if line.strip().startswith(key_upper + "="):
            new_lines.append(f"{key_upper}={value}")
            found = True
        else:
            new_lines.append(line)
    
    if not found:
        new_lines.append(f"{key_upper}={value}")
    
    OLLAMA_CONFIG_FILE.write_text("\n".join(new_lines) + "\n")
    SETTINGS[key] = value

load_settings()
OLLAMA_API_URL = SETTINGS["ollama_host"]
MOUSE_ENABLED = True

def get_cpu_usage():
    try:
        with open('/proc/stat', 'r') as f:
            line1 = f.readline()
        time.sleep(0.05)
        with open('/proc/stat', 'r') as f:
            line2 = f.readline()
        
        def parse_stat(line):
            parts = line.split()
            idle = float(parts[4])
            total = sum(float(x) for x in parts[1:])
            return idle, total
        
        idle1, total1 = parse_stat(line1)
        idle2, total2 = parse_stat(line2)
        
        diff_idle = idle2 - idle1
        diff_total = total2 - total1
        
        if diff_total == 0:
            return 0.0
        return max(0.0, min(100.0, (1.0 - diff_idle / diff_total) * 100.0))
    except Exception:
        return 0.0

def get_cpu_freq():
    try:
        freq_files = list(pathlib.Path('/sys/devices/system/cpu').glob('cpu*/cpufreq/scaling_cur_freq'))
        if not freq_files:
            return 0.0
        
        total_freq = 0
        count = 0
        for fpath in freq_files:
            try:
                total_freq += int(fpath.read_text().strip())
                count += 1
            except (IOError, ValueError):
                continue
        
        if count > 0:
            return (total_freq / count) / 1000.0  # Average in MHz
    except Exception:
        pass
    return 0.0

def get_ram_usage():
    try:
        with open('/proc/meminfo', 'r') as f:
            lines = f.readlines()
        mem_info = {}
        for line in lines:
            parts = line.split(':')
            if len(parts) == 2:
                mem_info[parts[0].strip()] = int(parts[1].strip().split()[0])
        
        total = mem_info.get('MemTotal', 0)
        available = mem_info.get('MemAvailable', mem_info.get('MemFree', 0))
        
        if total > 0:
            total_gb = total / (1024 * 1024)
            available_gb = available / (1024 * 1024)
            used_gb = total_gb - available_gb
            return total_gb, available_gb, used_gb
    except Exception:
        pass
    return 0.0, 0.0, 0.0

def get_cpu_temp():
    try:
        paths = [
            '/sys/class/thermal/thermal_zone0/temp',
            '/sys/class/thermal/thermal_zone1/temp',
            '/sys/class/hwmon/hwmon0/temp1_input',
            '/sys/class/hwmon/hwmon1/temp1_input',
        ]
        for p in paths:
            if os.path.exists(p):
                with open(p, 'r') as f:
                    return float(f.read().strip()) / 1000.0
    except Exception:
        pass
    return 0.0

def get_system_temps():
    temps = []
    temp_dict = {}
    # This will be used as the overall system 'cpu_temp' for indicators
    max_sys_temp = 0.0
    try:
        output = subprocess.check_output(["sensors", "-j"], text=True, errors="replace", stderr=subprocess.DEVNULL)
        data = json.loads(output)
        for adapter, sensors_dict in data.items():
            if adapter == "Adapter": continue
            for sensor_name, readings in sensors_dict.items():
                if isinstance(readings, dict):
                    for k, v in readings.items():
                        if k.endswith("_input") and "temp" in k:
                            temp_val = float(v)
                            # Track max for overall system status
                            max_sys_temp = max(max_sys_temp, temp_val)
                            
                            short_adapter = adapter.split('-')[0].upper()
                            # Mapping: original -> short
                            replacements = {
                                "AMDGPU": "GPU",
                                "K10TEMP": "K10",
                                "CORETEMP": "CPU",
                                "NVME": "SSD",
                                "ACPI": "SYS",
                                "R8169": "NET"
                            }
                            for old, new in replacements.items():
                                short_adapter = short_adapter.replace(old, new)
                            
                            # Hide primary sensors from the "System temps" list to keep it clean
                            if short_adapter in ["CPU", "K10", "GPU", "SYS", "SYSTZ", "ACPI", "ACPITZ"]:
                                continue

                            # Simplify adapter name (remove ugly trailing bus IDs like _0_200:00 or -pci)
                            label = short_adapter.split('_')[0]
                            label = label.split('-')[0]
                            
                            # Use a dict to deduplicate by generic label (keep the highest temp for that device type)
                            temp_dict[label] = max(temp_dict.get(label, 0.0), temp_val)
    except Exception:
        pass
    
    # Sort labels to keep the UI consistent
    for label in sorted(temp_dict.keys()):
        temps.append(f"{label}:{temp_dict[label]:.0f}°C")
    
    if max_sys_temp == 0.0:
        max_sys_temp = get_cpu_temp()
        
    return max_sys_temp, temps

GPU_TOOLS = ["auto", "nvidia-smi", "amd-smi", "rocm-smi", "none"]

def detect_gpu_tool():
    if SETTINGS["gpu_tool"] != "auto":
        return SETTINGS["gpu_tool"]
    for tool in ["nvidia-smi", "amd-smi", "rocm-smi"]:
        if subprocess.call(["which", tool], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) == 0:
            return tool
    return "none"

# Initialization of log and SMI state
LOG_HISTORY_MAXLEN = 5000  # Reduced for performance; enough for typical session
log_lines = deque(maxlen=LOG_HISTORY_MAXLEN)
# Cache for log lines: absolute_idx -> (raw_content, sanitized_content, {width: wrapped_segments}, in_thought)
# This prevents redundant regex and wrapping calculations on every frame.
log_cache = {}

log_lines_total_count = 0
smi_text = ["Loading GPU status..."]
latest_cpu_temp = 0.0
error_messages = {}
log_lock = threading.Lock()
smi_lock = threading.Lock()
error_lock = threading.Lock()
log_ready = threading.Event()
smi_ready = threading.Event()
smi_poll_trigger = threading.Event()
_tail_proc = None  # module-level reference so we can terminate on exit
last_log_update = time.time()

# ── Optimisation state ────────────────────────────────────────────────────────
# Monotonic version counters; incremented by background threads so the main
# loop can detect changes without expensive content comparisons.
log_version = 0          # bumped inside log_lock whenever log_lines is updated
smi_version = 0          # bumped inside smi_lock whenever smi_text is updated

# Top-level cache for the visible log area
_visible_log_cache = None
_visible_log_cache_key = None

# Event set by background threads to wake the main-loop idle wait.
render_event = threading.Event()

# Per-model /api/show param cache: model_name -> (fetch_timestamp, params_str)
_model_params_cache: dict = {}
MODEL_PARAMS_CACHE_TTL = 30.0  # seconds between /api/show refreshes per model
ANSI_ESCAPE_RE = re.compile(r"\x1b(?:\[[0-?]*[ -/]*[@-~]|\][^\x07]*(?:\x07|\x1b\\)|[ -/]*[@-~])")
LITERAL_ANSI_ESCAPE_RE = re.compile(r"\\033(?:\[[0-?]*[ -/]*[@-~]|\][^\x07]*(?:\x07|\\033\\)|[ -/]*[@-~])")
CONTROL_CHARS_RE = re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]")
ROLE_MARKERS = {
    "### USER": 1,
    "### ASSISTANT": 2,
    "### SYSTEM": 2,
}
ANSI_TOKEN_RE = re.compile(r"(?:\x1b|\\033)\[([0-9;]*)m")
ansi_color_pairs = {}
next_ansi_color_pair = 20
SCROLL_LINE_STEP = 3
STARTUP_LOGO_SECONDS = 2.0
# Idle-wait timeouts for the main loop's event-driven render cycle.
# A shorter wait is used immediately after the user interacted so key-repeat
# bursts are picked up promptly; a longer wait is used when truly idle.
IDLE_WAIT_AFTER_INPUT = 0.04   # seconds – ~25 fps ceiling when scrolling
IDLE_WAIT_DEFAULT     = 0.15   # seconds – ~7 fps ceiling when nothing changes
# Number of render frames during which the SMI-panel height reservation is
# cleared after a panel toggle so the layout can shrink to fit.
SMI_RESET_FRAMES = 10

def sanitize_render_text(text):
    text = ANSI_ESCAPE_RE.sub("", text)
    text = LITERAL_ANSI_ESCAPE_RE.sub("", text)
    text = text.replace("\r", "")
    text = text.replace("\t", "    ")
    text = text.replace("<|im_start|>system", "### SYSTEM")
    text = text.replace("<|im_start|>user", "### USER")
    text = text.replace("<|im_start|>assistant", "### ASSISTANT")
    text = text.replace("<|im_start|>", "")
    text = text.replace("<|im_end|>", "")
    text = text.replace("<|endoftext|>", "")
    return CONTROL_CHARS_RE.sub("", text)

def wrap_render_line(line, width):
    if width <= 4:
        return [line[:width]]
    if not line.strip():
        return [line] if line else [""]

    # Detect prefix (indentation or history marker)
    prefix = ""
    if line.startswith("| "):
        prefix = "| "
    elif line.startswith("  "):
        # Match leading whitespace up to width/3
        ws_match = re.match(r"^(\s+)", line)
        if ws_match:
            prefix = ws_match.group(1)[:width//3]

    content_width = width - len(prefix)
    if content_width <= 0:
        return [line[:width]]

    first_segment = line[:width]
    remaining = line[width:]
    
    if not remaining:
        return [first_segment]
    
    segments = [first_segment]
    for i in range(0, len(remaining), content_width):
        segments.append(prefix + remaining[i:i + content_width])
    return segments

def role_color_pair_for_line(line):
    for marker, color_pair in ROLE_MARKERS.items():
        if line.startswith(marker):
            return color_pair
    return None

def is_role_marker_line(line):
    return role_color_pair_for_line(line) is not None

def is_separator_line(line):
    return line.startswith("====================") or line.startswith("--------------------------------------------------------------------------------")

def line_opens_thought(line):
    return "<think>" in line or "[THOUGHT]" in line

def line_closes_thought(line):
    return "</think>" in line or "[/THOUGHT]" in line

def get_cached_log_entry(abs_idx, raw_content, width, log_snapshot, snapshot_offset):
    """Retrieve or build a cached entry for a log line.
    
    Entry format: {
        "raw": str,
        "sanitized": str,
        "wrapped": {width: [segments]},
        "in_thought": bool
    }
    """
    entry = log_cache.get(abs_idx)
    
    # If raw content changed, we must rebuild everything for this absolute index
    if not entry or entry["raw"] != raw_content:
        sanitized = sanitize_render_text(raw_content)
        
        # Calculate thought state efficiently
        in_thought = False
        if line_is_in_thought(snapshot_offset, log_snapshot):
            in_thought = True
            
        entry = {
            "raw": raw_content,
            "sanitized": sanitized,
            "wrapped": {},
            "in_thought": in_thought
        }
        log_cache[abs_idx] = entry
    
    # Check if we have the wrapped segments for this specific width
    if width not in entry["wrapped"]:
        entry["wrapped"][width] = wrap_render_line(entry["sanitized"], width)
        
    return entry

def line_is_in_thought(source_idx, log_snapshot):
    # This is a bit expensive, but we now cache the result in get_cached_log_entry
    if source_idx < 0 or source_idx >= len(log_snapshot):
        return False
    # Scan back up to 500 lines to find if we are inside a thought block
    for j in range(source_idx, max(-1, source_idx - 500), -1):
        check_line = sanitize_render_text(log_snapshot[j])
        if line_opens_thought(check_line):
            if line_closes_thought(check_line):
                return max(check_line.rfind("</think>"), check_line.rfind("[/THOUGHT]")) < max(
                    check_line.rfind("<think>"), check_line.rfind("[THOUGHT]")
                )
            return True
        if line_closes_thought(check_line) or is_separator_line(check_line):
            return False
    return False

def render_attr_for_log_line(entry, line, color_pair=None):
    if color_pair is None:
        color_pair = curses.color_pair

    # Context history marker (prefixed by ollama_watcher.py)
    if line.startswith("| "):
        return color_pair(8)

    role_color_pair = role_color_pair_for_line(line)
    if role_color_pair is not None:
        return color_pair(role_color_pair) | curses.A_BOLD
    if is_separator_line(line):
        return color_pair(3) | curses.A_BOLD
    if line_opens_thought(line) or line_closes_thought(line):
        return color_pair(4) | curses.A_BOLD
    if entry["in_thought"]:
        return color_pair(4)
    return color_pair(0)

def visible_ansi_text(line):
    return ANSI_TOKEN_RE.sub("", line)

def ansi_attr(fg_color, bold):
    global next_ansi_color_pair

    attr = curses.A_BOLD if bold else curses.A_NORMAL
    if fg_color is None:
        return attr

    if not curses.has_colors() or fg_color >= curses.COLORS:
        return attr

    pair = ansi_color_pairs.get(fg_color)
    if pair is None:
        pair = next_ansi_color_pair
        next_ansi_color_pair += 1
        try:
            curses.init_pair(pair, fg_color, -1)
        except curses.error:
            return attr
        ansi_color_pairs[fg_color] = pair

    return attr | curses.color_pair(pair)

def render_ansi_line(stdscr, y, x, line, max_width):
    fg_color = None
    bold = False
    pos = 0
    draw_x = x

    for match in ANSI_TOKEN_RE.finditer(line):
        chunk = line[pos:match.start()]
        if chunk and draw_x < max_width:
            try:
                stdscr.addstr(y, draw_x, chunk[:max_width - draw_x], ansi_attr(fg_color, bold))
            except curses.error:
                pass
            draw_x += len(chunk)

        codes = [int(code) for code in match.group(1).split(";") if code.isdigit()]
        i = 0
        while i < len(codes):
            code = codes[i]
            if code == 0:
                fg_color = None
                bold = False
            elif code == 1:
                bold = True
            elif code == 38 and i + 2 < len(codes) and codes[i + 1] == 5:
                fg_color = codes[i + 2]
                i += 2
            elif 30 <= code <= 37:
                fg_color = code - 30
            elif 90 <= code <= 97:
                fg_color = code - 90 + 8
            elif code == 39:
                fg_color = None
            i += 1

        pos = match.end()

    chunk = line[pos:]
    if chunk and draw_x < max_width:
        try:
            stdscr.addstr(y, draw_x, chunk[:max_width - draw_x], ansi_attr(fg_color, bold))
            draw_x += len(chunk[:max_width - draw_x])
        except curses.error:
            pass

    # Clear remainder of line to prevent ghost characters
    try:
        stdscr.clrtoeol()
    except curses.error:
        pass

def build_visible_log_lines(width):
    """Return (visible_lines, log_snapshot, total_count).

    visible_lines elements are (absolute_line_idx, segment_text, entry).
    """
    global _visible_log_cache, _visible_log_cache_key

    with log_lock:
        log_snapshot = list(log_lines)
        total_count = log_lines_total_count
        v = log_version

    # Return cached result if width and version match
    key = (width, v)
    if _visible_log_cache_key == key:
        return _visible_log_cache

    # Build wrapped lines using the per-line cache
    visible = []
    first_abs_idx = total_count - len(log_snapshot)

    for idx, line in enumerate(log_snapshot):
        abs_idx = first_abs_idx + idx
        entry = get_cached_log_entry(abs_idx, line, width, log_snapshot, idx)
        for segment in entry["wrapped"][width]:
            visible.append((abs_idx, segment, entry))

    # Cleanup log_cache periodically to remove absolute indices that are no longer in the deque
    if len(log_cache) > LOG_HISTORY_MAXLEN * 1.5:
        # Only keep indices that are within the current range
        current_indices = set(range(first_abs_idx, total_count))
        stale_indices = [idx for idx in log_cache if idx not in current_indices]
        for idx in stale_indices:
            log_cache.pop(idx, None)

    result = (visible, log_snapshot, total_count)
    _visible_log_cache = result
    _visible_log_cache_key = key
    return result
def collect_input(stdscr):
    keys = []
    while True:
        key = stdscr.getch()
        if key == -1:
            return keys
        keys.append(key)

def apply_input(stdscr, keys, scroll_pos, auto_scroll, log_line_count, log_h):
    max_scroll = max(0, log_line_count - log_h)
    changed = False
    smi_changed = False

    if keys:
        for key in keys:
            if key == curses.KEY_UP:
                old_pos = scroll_pos
                scroll_pos -= SCROLL_LINE_STEP
                if scroll_pos < 0:
                    scroll_pos = 0
                if scroll_pos != old_pos:
                    auto_scroll = False
                    changed = True
            elif key == curses.KEY_DOWN:
                old_pos = scroll_pos
                scroll_pos += SCROLL_LINE_STEP
                if scroll_pos >= max_scroll:
                    scroll_pos = max_scroll
                    # Only auto-resume if we actually moved TO hit the bottom
                    if old_pos < max_scroll:
                        auto_scroll = True
                else:
                    auto_scroll = False
                if scroll_pos != old_pos:
                    changed = True
            elif key == curses.KEY_PPAGE:
                old_pos = scroll_pos
                scroll_pos -= log_h
                if scroll_pos < 0:
                    scroll_pos = 0
                if scroll_pos != old_pos:
                    auto_scroll = False
                    changed = True
            elif key == curses.KEY_NPAGE:
                old_pos = scroll_pos
                scroll_pos += log_h
                if scroll_pos >= max_scroll:
                    scroll_pos = max_scroll
                    # Only auto-resume if we actually moved TO hit the bottom
                    if old_pos < max_scroll:
                        auto_scroll = True
                else:
                    auto_scroll = False
                if scroll_pos != old_pos:
                    changed = True
            elif key == ord('f') or key == ord('F'):
                auto_scroll = not auto_scroll
                changed = True
            elif key == ord('g') or key == ord('G'):
                save_setting("show_gpu", not SETTINGS["show_gpu"])
                changed = True
                smi_changed = True
                smi_poll_trigger.set()
            elif key == ord('c') or key == ord('C'):
                save_setting("show_cpu", not SETTINGS["show_cpu"])
                changed = True
                smi_changed = True
                smi_poll_trigger.set()
            elif key == ord('l') or key == ord('L'):
                save_setting("show_log", not SETTINGS["show_log"])
                changed = True
                smi_changed = True # Allow SMI to expand/shrink
            elif key == ord('h') or key == ord('H'):
                save_setting("show_hints", not SETTINGS["show_hints"])
                changed = True
            elif key == ord('t') or key == ord('T'):
                toggle_gpu_tool()
                changed = True
                smi_changed = True
                smi_poll_trigger.set()
            elif key == 19: # Ctrl+S
                toggle_mouse(stdscr, not MOUSE_ENABLED)
                changed = True
            elif key == curses.KEY_MOUSE:
                try:
                    _, _, _, _, bstate = curses.getmouse()
                    if bstate & 0x10000: # curses.BUTTON4_PRESSED/SCROLL_UP
                        old_pos = scroll_pos
                        scroll_pos -= SCROLL_LINE_STEP
                        if scroll_pos < 0:
                            scroll_pos = 0
                        if scroll_pos != old_pos:
                            auto_scroll = False
                            changed = True
                    elif bstate & 0x200000: # curses.BUTTON5_PRESSED/SCROLL_DOWN
                        old_pos = scroll_pos
                        scroll_pos += SCROLL_LINE_STEP
                        if scroll_pos >= max_scroll:
                            scroll_pos = max_scroll
                            # Only auto-resume if we actually moved TO hit the bottom
                            if old_pos < max_scroll:
                                auto_scroll = True
                        else:
                            auto_scroll = False
                        if scroll_pos != old_pos:
                            changed = True
                except curses.error:
                    pass

    if auto_scroll:
        scroll_pos = max_scroll
    else:
        scroll_pos = min(max(0, scroll_pos), max_scroll)

    return scroll_pos, auto_scroll, changed, smi_changed

def set_error(key, message):
    with error_lock:
        if message:
            error_messages[key] = sanitize_render_text(message)
        else:
            error_messages.pop(key, None)
    # Wake the main loop so the error banner updates immediately.
    # Called outside error_lock to keep the call site simple; render_event
    # is thread-safe and never acquired together with any other lock.
    render_event.set()

def get_val_color(val, t1, t2, t3, t4, color_pair_func=curses.color_pair):
    if val < t1:
        return color_pair_func(5)  # Blue (Cold)
    elif val < t2:
        return color_pair_func(2)  # Green (Optimal)
    elif val < t3:
        return color_pair_func(3)  # Yellow (Warm)
    elif val < t4:
        return color_pair_func(6)  # Orange (Hot-Warm)
    else:
        return color_pair_func(11) # Red (Hot)

def get_temp_color(temp, color_pair_func=curses.color_pair):
    return get_val_color(temp, 35, 55, 70, 85, color_pair_func)

def toggle_gpu_tool():
    current = SETTINGS["gpu_tool"]
    try:
        idx = (GPU_TOOLS.index(current) + 1) % len(GPU_TOOLS)
    except ValueError:
        idx = 0
    new_tool = GPU_TOOLS[idx]
    save_setting("gpu_tool", new_tool)
    return new_tool

def set_smi_text(lines, cpu_temp=0.0):
    global smi_text, latest_cpu_temp, smi_version
    with smi_lock:
        smi_text = lines
        latest_cpu_temp = cpu_temp
        smi_version += 1
    smi_ready.set()
    render_event.set()  # wake main-loop idle wait

def get_smi_snapshot():
    with smi_lock:
        return list(smi_text), latest_cpu_temp, smi_version

def poll_smi():
    while True:
        # GPU detection and polling
        tool = detect_gpu_tool()
        hw_lines = []
        if tool != "none":
            try:
                # Try standard execution first
                output = subprocess.check_output([tool], text=True, errors="replace", stderr=subprocess.STDOUT)
                
                # Check for common permission error message regarding process names (e.g. amd-smi)
                if "Elevated permissions" in output or "Permission denied" in output:
                    try:
                        # Try sudo -n (non-interactive, fails if password required)
                        sudo_output = subprocess.check_output(["sudo", "-n", tool], text=True, errors="replace", stderr=subprocess.STDOUT)
                        output = sudo_output
                    except Exception:
                        # If sudo failed, add a helpful tip to the output
                        if "Elevated permissions" in output:
                            output += "\n\033[93mTip: Run 'sudo usermod -a -G render,video $USER' and restart session to see process names.\033[0m"
                
                hw_lines = output.splitlines()
            except Exception:
                hw_lines = [f"\033[31m({tool} unavailable)\033[0m"]
        else:
            hw_lines = ["\033[90m(no GPU tool detected)\033[0m"]

        # CPU load and temp
        cpu_load = get_cpu_usage()
        cpu_temp, sys_temps = get_system_temps()
        ram_total, ram_avail, ram_used = get_ram_usage()

        # For nvidia-smi, GPU temps don't appear in sensors — extract them directly
        if tool == "nvidia-smi":
            try:
                nv_out = subprocess.check_output(
                    ["nvidia-smi", "--query-gpu=index,temperature.gpu", "--format=csv,noheader"],
                    text=True, errors="replace", stderr=subprocess.DEVNULL,
                )
                nv_entries = []
                for nv_line in nv_out.strip().splitlines():
                    parts = [p.strip() for p in nv_line.split(",")]
                    if len(parts) >= 2 and parts[1].lstrip("-").isdigit():
                        nv_entries.append((int(parts[0]), float(parts[1])))
                multi_gpu = len(nv_entries) > 1
                for idx, temp in nv_entries:
                    label = f"GPU{idx}" if multi_gpu else "GPU"
                    sys_temps.append(f"{label}:{temp:.0f}°C")
                    cpu_temp = max(cpu_temp, temp)
            except Exception:
                pass
        
        # Parallel sessions allowed
        num_parallel = get_ollama_num_parallel()

        # GPU/CPU split from 'ollama ps'
        ps_info = parse_ollama_ps()

        # Model details from /api/ps
        model_lines = []
        try:
            req = urllib.request.Request(f"{OLLAMA_API_URL}/api/ps", method="GET")
            with urllib.request.urlopen(req, timeout=1) as response:
                data = json.loads(response.read().decode())
                models = data.get("models", [])
                if models:
                    current_model_names = {m.get("name", "") for m in models}
                    # Evict cache entries for models no longer active
                    stale = [k for k in _model_params_cache if k not in current_model_names]
                    for k in stale:
                        del _model_params_cache[k]
                    for m in models:
                        name = m.get("name", "unknown")
                        ctx = m.get("context_length", 0)
                        size = m.get("size", 0)
                        size_vram = m.get("size_vram", 0)

                        # GPU/CPU split: prefer 'ollama ps', fall back to size_vram ratio
                        processor = ps_info.get(name, "")
                        if not processor and size > 0:
                            gpu_pct = int(round(size_vram / size * 100))
                            cpu_pct = 100 - gpu_pct
                            processor = f"{gpu_pct}% GPU / {cpu_pct}% CPU"

                        size_str = f"{size / (1024**3):.1f} GB" if size > 0 else "? GB"
                        
                        param_details_str = _get_model_params(name)

                        model_lines.append(f"  \033[1;32m{name}\033[0m ({size_str} | {processor or 'unknown'})")
                        model_lines.append(f"    \033[34m└\033[0m ctx:{ctx}{param_details_str}")
                else:
                    model_lines = ["  \033[90m(no active models)\033[0m"]
                set_error("ollama", None)
        except Exception:
            model_lines = ["  \033[31m(could not reach Ollama API)\033[0m"]
            set_error("ollama", "Ollama is not reachable. Run 'ollama serve' to start it.")

        full_smi_lines = []
        header = f"\033[1;36m=== OLLAMA  parallel:{num_parallel}  tool:{tool} ===\033[0m"
        full_smi_lines.append(header)
        full_smi_lines.extend(model_lines)
        
        if SETTINGS["show_cpu"]:
            full_smi_lines.append("") # Spacer before CPU
            cpu_pct = f"{cpu_load:2.0f}%"
            cpu_freq = get_cpu_freq()
            freq_str = ""
            if cpu_freq > 0:
                if cpu_freq >= 1000:
                    freq_str = f" {cpu_freq/1000:.1f}GHz"
                else:
                    freq_str = f" {cpu_freq:.0f}MHz"
            
            temp_str = f" {cpu_temp:2.0f}°C"
            cpu_line = f"CPU:{cpu_pct}{freq_str}{temp_str}"
            
            if ram_total > 0:
                cpu_line += f" | RAM:{ram_used:.1f}/{ram_total:.1f}GiB"
            
            if sys_temps:
                cpu_line += " | " + " ".join(sys_temps)
            full_smi_lines.append(cpu_line)
            
        if SETTINGS["show_gpu"]:
            full_smi_lines.append("") # Spacer before GPU
            full_smi_lines.extend(hw_lines)
            
        set_smi_text(full_smi_lines, cpu_temp=cpu_temp)
        smi_poll_trigger.wait(timeout=2.0)
        smi_poll_trigger.clear()

def get_error_lines(width):
    with error_lock:
        messages = list(error_messages.values())
    if not messages:
        return []
    text = " | ".join(messages)
    return wrap_render_line(text, width)

def tail_log():
    global _tail_proc, last_log_update
    import fcntl
    try:
        _tail_proc = subprocess.Popen(
            ['tail', '-f', '-n', '2000', READABLE_LOG],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        p = _tail_proc
        log_ready.set()
        fd = p.stdout.fileno()
        fl = fcntl.fcntl(fd, fcntl.F_GETFL)
        fcntl.fcntl(fd, fcntl.F_SETFL, fl | os.O_NONBLOCK)

        current_line = ""
        while True:
            try:
                chunk_bytes = p.stdout.read(4096)
            except BlockingIOError:
                chunk_bytes = None

            if chunk_bytes:
                last_log_update = time.time()
                set_error("log", None)
                try:
                    text = chunk_bytes.decode('utf-8', errors='replace')
                except Exception:
                    text = ""
                
                parts = text.split('\n')
                with log_lock:
                    global log_lines_total_count, log_version
                    if len(parts) == 1:
                        current_line += parts[0]
                        if log_lines:
                            log_lines[-1] = current_line.replace('\t', '    ')
                        else:
                            log_lines.append(current_line.replace('\t', '    '))
                            log_lines_total_count += 1
                    else:
                        current_line += parts[0]
                        if log_lines:
                            log_lines[-1] = current_line.replace('\t', '    ')
                        else:
                            log_lines.append(current_line.replace('\t', '    '))
                            log_lines_total_count += 1

                        for part in parts[1:-1]:
                            log_lines.append(part.replace('\t', '    '))
                            log_lines_total_count += 1

                        current_line = parts[-1]
                        log_lines.append(current_line.replace('\t', '    '))
                        log_lines_total_count += 1
                    log_version += 1  # signal cache invalidation
                # Wake the main loop. Called outside log_lock intentionally —
                # holding a lock across render_event.set() is unnecessary and
                # would create an avoidable lock ordering risk.
                render_event.set()
            else:
                if p.poll() is not None:
                    error = ""
                    if p.stderr is not None:
                        try:
                            error = p.stderr.read().decode('utf-8', errors='replace').strip()
                        except Exception:
                            error = ""
                    set_error("log", error or "Log tail stopped")
                    return
                # Block up to 0.25 s waiting for the tail process to write
                # more data; this replaces the original busy-sleep(0.05).
                # select.select() is called outside log_lock to avoid holding
                # the lock across a blocking call.
                try:
                    select.select([p.stdout], [], [], 0.25)
                except (ValueError, OSError):
                    set_error("log", "Log tail interrupted")
                    return
    except Exception as e:
        set_error("log", f"Log tail error: {e}")
        log_ready.set()

def get_ollama_num_parallel():
    """Return OLLAMA_NUM_PARALLEL from the current env or the running ollama process env."""
    val = os.environ.get("OLLAMA_NUM_PARALLEL")
    if val:
        return val
    try:
        pid_out = subprocess.check_output(
            ['pgrep', '-x', 'ollama'],
            text=True,
            timeout=2,
            stderr=subprocess.DEVNULL,
        ).strip()
        if pid_out:
            pid = pid_out.splitlines()[0].strip()
            with open(f'/proc/{pid}/environ', 'rb') as f:
                env_data = f.read()
            for entry in env_data.split(b'\x00'):
                if entry.startswith(b'OLLAMA_NUM_PARALLEL='):
                    return entry.split(b'=', 1)[1].decode()
    except Exception:
        pass
    return "auto"

def parse_ollama_ps():
    """Run 'ollama ps' and return a dict of model_name -> processor_string."""
    result = {}
    try:
        ps_output = subprocess.check_output(
            ['ollama', 'ps'],
            text=True,
            errors="replace",
            timeout=3,
            stderr=subprocess.DEVNULL,
        )
        ps_lines = ps_output.strip().splitlines()
        if len(ps_lines) < 2:
            return result
        header_line = ps_lines[0].upper()
        proc_col = header_line.find("PROCESSOR")
        until_col = header_line.find("UNTIL")
        if proc_col < 0:
            return result
        for row in ps_lines[1:]:
            if not row.strip():
                continue
            name_field = row[:proc_col].strip()
            name = name_field.split()[0] if name_field else ""
            if until_col > proc_col:
                processor = row[proc_col:until_col].strip()
            else:
                processor = row[proc_col:].strip()
            if name:
                result[name] = processor
    except Exception:
        pass
    return result

def _get_model_params(model_name):
    """Fetch model parameters from /api/show and return a formatted string.

    Results are cached per model name for MODEL_PARAMS_CACHE_TTL seconds so
    the expensive HTTP call is not repeated on every telemetry cycle.
    """
    now = time.time()
    cached = _model_params_cache.get(model_name)
    if cached is not None:
        fetch_ts, params_str = cached
        if now - fetch_ts < MODEL_PARAMS_CACHE_TTL:
            return params_str

    params_of_interest = [
        "temperature", "num_batch", "num_gqa",
        "top_k", "top_p", "tfs_z"
    ]
    try:
        req_body = json.dumps({"name": model_name}).encode()
        req = urllib.request.Request(f"{OLLAMA_API_URL}/api/show", data=req_body, method="POST")
        req.add_header('Content-Type', 'application/json')
        with urllib.request.urlopen(req, timeout=1) as response:
            data = json.loads(response.read().decode())
            param_str = data.get("parameters", "")
            if not param_str:
                _model_params_cache[model_name] = (now, "")
                return ""
            
            params = {}
            for line in param_str.splitlines():
                parts = line.strip().split(None, 1)
                if len(parts) == 2:
                    params[parts[0]] = parts[1]

            param_list = []
            for p in params_of_interest:
                if p in params:
                    # Shorten names for display
                    short_name = p.replace("temperature", "temp").replace("num_", "")
                    param_list.append(f"{short_name}:{params[p]}")
            
            result = (" | " + " ".join(param_list)) if param_list else ""
            _model_params_cache[model_name] = (now, result)
            return result

    except Exception:
        _model_params_cache[model_name] = (now, "")
        return ""

def toggle_mouse(stdscr, enable):
    global MOUSE_ENABLED
    MOUSE_ENABLED = enable
    if enable:
        curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
        # Using print for escape sequences in curses can be tricky, but keeping existing logic
        print("\033[?1003h", end="") 
    else:
        curses.mousemask(0)
        print("\033[?1003l", end="")
    stdscr.refresh()

def main(stdscr):
    # Load ASCII Headers
    try:
        with open(HEADER_FILE, "r") as f:
            header_lines = f.read().splitlines()
    except FileNotFoundError:
        header_lines = ["WATCH OLLAMA", "Monitoring, Benchmarking, & Management Suite"]
    
    try:
        with open(HEADER_SMALL_FILE, "r") as f:
            header_small_lines = f.read().splitlines()
    except FileNotFoundError:
        header_small_lines = ["WATCH OLLAMA"]
    
    welcome_msg = ["", "Welcome to watch-ollama. Press 'q' to quit."]
    header_full = header_lines + welcome_msg
    header_small = header_small_lines + welcome_msg
    
    curses.curs_set(0)
    stdscr.nodelay(1)
    stdscr.keypad(True)
    stdscr.timeout(0)  # non-blocking getch(); timing is handled by render_event.wait()
    
    # Enable mouse events for scrolling
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
    global MOUSE_ENABLED
    MOUSE_ENABLED = True
    
    # Setup Colors
    curses.start_color()
    curses.use_default_colors()
    
    curses.init_pair(1, curses.COLOR_CYAN, -1)     # USER block
    curses.init_pair(2, curses.COLOR_GREEN, -1)    # ASSISTANT/OK
    curses.init_pair(3, curses.COLOR_YELLOW, -1)   # WARNING/WARN
    curses.init_pair(4, curses.COLOR_MAGENTA, -1)  # THOUGHT block
    curses.init_pair(11, curses.COLOR_RED, -1)     # DANGER/HOT
    curses.init_pair(5, curses.COLOR_BLUE, -1)      # COLD
    
    # Orange (if supported by terminal)
    if curses.COLORS >= 256:
        curses.init_pair(6, 208, -1) 
    else:
        curses.init_pair(6, curses.COLOR_YELLOW, -1) # Fallback to Yellow
    
    # Ensure standard color pairs are usable if missing
    if curses.COLORS >= 8:
        pass # Everything is mapped. 1, 2, 3, 11 are the key ones used.
    
    t_log = threading.Thread(target=tail_log, daemon=True)
    t_log.start()
    
    t_smi = threading.Thread(target=poll_smi, daemon=True)
    t_smi.start()

    startup_until = time.time() + STARTUP_LOGO_SECONDS
    while time.time() < startup_until:
        max_y, max_x = stdscr.getmaxyx()
        stdscr.erase()

        # Choose header based on width
        # The full header is ~115 chars wide
        current_header = header_full if max_x > 120 else header_small

        start_y = max(0, (max_y - len(current_header)) // 2)
        for i, line in enumerate(current_header):
            y = start_y + i
            if y >= max_y:
                break
            visible_line = visible_ansi_text(line)
            x = max(0, (max_x - len(visible_line)) // 2)
            render_ansi_line(stdscr, y, x, line, max_x - 1)

        stdscr.refresh()
        key = stdscr.getch()
        if key == 3 or key == ord('q') or key == ord('Q') or key == 27:
            return
        time.sleep(0.05)

    scroll_pos = 0
    auto_scroll = True
    reserved_smi_lines_by_height = {}
    last_snapshot_len = 0
    smi_reset_counter = 0

    # ── Dirty-redraw tracking ────────────────────────────────────────────────
    # We only call stdscr.erase()/refresh() when something actually changed.
    render_dirty = True      # force first render
    last_term_size = (-1, -1)
    last_smi_ver = -1
    last_log_ver = -1
    last_error_sig: tuple = ()
    last_scroll = -1
    last_auto = None
    visible_log_lines: list = []
    last_visible_lines: list = []
    log_snapshot: list = []
    input_was_active = False  # used to shorten the idle wait after keypresses

    while True:
        # ── IDLE WAIT ────────────────────────────────────────────────────
        # When nothing is dirty, block until a background thread signals
        # new data or a short timeout elapses so we catch terminal resizes
        # and key-repeat bursts promptly.
        if not render_dirty:
            # If the log was recently updated, use a very short wait for smoothness
            is_log_active = (time.time() - last_log_update < 1.0)
            wait_s = 0.02 if is_log_active else (IDLE_WAIT_AFTER_INPUT if input_was_active else IDLE_WAIT_DEFAULT)
            render_event.wait(timeout=wait_s)
            render_event.clear()

        # ── INPUT (non-blocking drain) ───────────────────────────────────
        # Drain all queued keys each iteration so held scroll keys do not
        # create a backlog that blocks a direction change.
        keys = collect_input(stdscr)
        if any(key == 3 or key == ord('q') or key == ord('Q') or key == 27 for key in keys):
            break

        # ── STATE SNAPSHOT ───────────────────────────────────────────────
        max_y, max_x = stdscr.getmaxyx()
        curr_term_size = (max_y, max_x)
        if curr_term_size != last_term_size:
            stdscr.clear() # Force full redraw on resize
        
        smi_snapshot, cpu_temp, curr_smi_ver = get_smi_snapshot()
        render_width = max(1, max_x - 1)
        active_errors = get_error_lines(render_width)
        curr_error_sig = tuple(active_errors)
        with log_lock:
            curr_log_ver = log_version

        # ── LOG LINES (cached) ───────────────────────────────────────────
        # Rebuild/fetch logs BEFORE apply_input so layout is accurate.
        visible_log_lines, log_snapshot, total_count = build_visible_log_lines(render_width)

        # ── LAYOUT (accurate dimensions for input) ───────────────────────
        # Allow SMI to take more space if needed, especially if log is hidden
        if SETTINGS["show_log"]:
            max_smi_lines = max(5, (max_y * 2) // 3) # Up to 2/3 of screen
        else:
            max_smi_lines = max(5, max_y - error_h - 2)

        observed_smi_lines = len(smi_snapshot) if smi_snapshot else 0

        if smi_reset_counter > 0:
            reserved_smi_lines_by_height.clear()
            smi_reset_counter -= 1

        reserved_smi_lines = reserved_smi_lines_by_height.get(max_y, 0)
        if reserved_smi_lines == 0:
            if SETTINGS["show_gpu"]:
                # Reserve at least 12 lines if GPU is enabled to avoid jumping
                smi_lines = min(max_smi_lines, max(12, observed_smi_lines))
            else:
                # Tight fit if only models/CPU are shown
                smi_lines = min(max_smi_lines, observed_smi_lines)
        else:
            smi_lines = reserved_smi_lines
        
        reserved_smi_lines_by_height[max_y] = smi_lines

        error_h = min(2, len(active_errors))
        if SETTINGS["show_log"]:
            log_h = max(1, max_y - smi_lines - error_h - 2)
        else:
            log_h = 0
            # If log is hidden, let SMI take all remaining space
            smi_lines = max_y - error_h - 1

        # ── DRIFT COMPENSATION ───────────────────────────────────────────
        # If we are paused, try to stay on the same absolute content even
        # if the deque dropped lines from the top.
        if not auto_scroll and visible_log_lines and last_scroll >= 0:
            # Find the absolute line index and segment offset we were on.
            if last_scroll < len(last_visible_lines):
                target_abs_idx, target_segment, _ = last_visible_lines[last_scroll]
                # Look for this same absolute content in the new list.
                found = False
                best_fallback = -1
                min_idx_diff = float('inf')

                for i, (abs_idx, segment, _) in enumerate(visible_log_lines):
                    if abs_idx == target_abs_idx:
                        if segment == target_segment:
                            scroll_pos = i
                            found = True
                            break
                        elif best_fallback == -1:
                            # If segment changed (due to resize), stay on the same absolute line
                            best_fallback = i
                    
                    # Track the closest available line in case our line was dropped
                    diff = abs(abs_idx - target_abs_idx)
                    if diff < min_idx_diff:
                        min_idx_diff = diff
                        if best_fallback == -1 or diff == 0:
                            best_fallback = i

                if not found:
                    if best_fallback != -1:
                        scroll_pos = best_fallback
                    elif visible_log_lines:
                        # If content is truly gone (dropped from deque), clamp to top or bottom
                        if target_abs_idx < visible_log_lines[0][0]:
                            scroll_pos = 0
                        else:
                            scroll_pos = max(0, len(visible_log_lines) - log_h)

        # Apply input using the accurate layout.
        scroll_pos, auto_scroll, input_changed, smi_changed = apply_input(
            stdscr, keys, scroll_pos, auto_scroll, len(visible_log_lines), log_h
        )
        if smi_changed or input_changed:
            stdscr.clear() # Wipe clean on state change to prevent artifacts
            if smi_changed:
                smi_reset_counter = SMI_RESET_FRAMES  # clear reservations to allow panel to shrink
        input_was_active = bool(input_changed)

        # ── DIRTY CHECK ──────────────────────────────────────────────────
        if (input_changed
                or curr_term_size != last_term_size
                or curr_smi_ver != last_smi_ver
                or curr_log_ver != last_log_ver
                or curr_error_sig != last_error_sig
                or scroll_pos != last_scroll
                or auto_scroll != last_auto):
            render_dirty = True

        if not render_dirty:
            last_visible_lines = visible_log_lines
            continue

        # Re-clamp scroll with the accurate wrapped-line count.
        max_scroll = max(0, len(visible_log_lines) - log_h)
        if auto_scroll:
            scroll_pos = max_scroll
        else:
            scroll_pos = min(max(0, scroll_pos), max_scroll)

        # ── RENDER ───────────────────────────────────────────────────────
        # We avoid stdscr.erase() here to prevent flickering. Section-specific
        # rendering now handles clearing its own lines via padding or clrtoeol.

        # Render SMI
        for i in range(smi_lines):
            line = smi_snapshot[i] if i < len(smi_snapshot) else ""
            try:
                if "CPU:" in line and ("RAM:" in line or "°C" in line):
                    # Robust parsing for the telemetry oneliner
                    # Format: CPU:4.1% 43.1°C | RAM:15/32G | adapter:58°C ...
                    parts = line.split(" | ")

                    curr_x = 0
                    def safe_addstr(text, attr=0):
                        nonlocal curr_x
                        if curr_x >= max_x - 1: return False
                        safe_text = text[:max_x - 1 - curr_x]
                        if not safe_text: return False
                        try:
                            stdscr.addstr(i, curr_x, safe_text, attr)
                        except curses.error:
                            pass
                        curr_x += len(safe_text)
                        return True

                    for idx, part in enumerate(parts):
                        if idx > 0:
                            if not safe_addstr(" | "): break

                        if part.startswith("CPU:"):
                            if not safe_addstr("CPU:", curses.A_BOLD): break
                            sub = part[4:].strip().split()
                            if not sub: continue
                            # Load % (first segment)
                            val_str = sub[0]
                            try:
                                val = float(val_str.replace("%", ""))
                                if not safe_addstr(" " + val_str, get_val_color(val, 25, 50, 75, 90)): break
                            except ValueError:
                                if not safe_addstr(" " + val_str): break

                            # Remaining segments (Frequency, Temperature, etc.)
                            for item in sub[1:]:
                                if "°C" in item:
                                    try:
                                        t_val = float(item.replace("°C", ""))
                                        t_color = get_temp_color(t_val)
                                        if not safe_addstr(" "): break
                                        if not safe_addstr(" 🌡 ", curses.A_REVERSE | t_color): break
                                        if not safe_addstr(" " + item, t_color): break
                                    except ValueError:
                                        if not safe_addstr(" " + item): break
                                else:
                                    if not safe_addstr(" " + item): break
                        elif part.startswith("RAM:"):
                            if not safe_addstr("RAM:", curses.A_BOLD): break
                            r_val_str = part[4:].strip()
                            if "/" in r_val_str:
                                try:
                                    v1, v2 = r_val_str.split('/')
                                    # Strip all non-numeric characters except the decimal point
                                    def clean_val(s):
                                        return "".join(c for c in s if c.isdigit() or c == '.')

                                    u_val = float(clean_val(v1))
                                    t_val = float(clean_val(v2))
                                    u_pct = (u_val / t_val) * 100 if t_val > 0 else 0

                                    r_color = get_val_color(u_pct, 25, 50, 75, 90)
                                    if not safe_addstr(" "): break
                                    # Show a small indicator block if usage is significant
                                    if u_pct > 75:
                                        if not safe_addstr(" !! ", curses.A_REVERSE | r_color): break

                                    if not safe_addstr(" " + r_val_str, r_color): break
                                except (ValueError, ZeroDivisionError):
                                    if not safe_addstr(" " + r_val_str): break
                        else:
                            # System temps
                            s_parts = part.split()
                            for s_idx, s_p in enumerate(s_parts):
                                if s_idx > 0:
                                    if not safe_addstr(" "): break
                                if ":" in s_p:
                                    try:
                                        name, t_val_str = s_p.split(":")
                                        if not safe_addstr(name + ":", curses.A_BOLD): break
                                        t_val = float(t_val_str.replace("°C", ""))
                                        t_color = get_temp_color(t_val)
                                        if not safe_addstr(t_val_str, t_color): break
                                    except ValueError:
                                        if not safe_addstr(s_p): break
                                else:
                                    if not safe_addstr(s_p): break
                    # Clear remainder of CPU/RAM line
                    try:
                        stdscr.clrtoeol()
                    except curses.error:
                        pass
                else:
                    render_ansi_line(stdscr, i, 0, line, max_x - 1)
            except (curses.error, ValueError, IndexError):
                try:
                    render_ansi_line(stdscr, i, 0, line, max_x - 1)
                except curses.error:
                    pass

        if smi_lines < max_y:
            try:
                stdscr.addstr(smi_lines, 0, ("-" * (max_x-1))[:max_x-1], curses.A_REVERSE)
            except curses.error:
                pass
        
        # Render Log
        if SETTINGS["show_log"]:
            for i in range(log_h):
                idx = scroll_pos + i
                if idx < len(visible_log_lines):
                    abs_idx, line, entry = visible_log_lines[idx]
                    color = render_attr_for_log_line(entry, line)
                    
                    try:
                        # Pad line with spaces to clear old content without erasing
                        stdscr.addstr(smi_lines + 1 + i, 0, line[:render_width].ljust(render_width), color)
                    except curses.error:
                        pass
                else:
                    # Clear empty log area
                    try:
                        stdscr.move(smi_lines + 1 + i, 0)
                        stdscr.clrtoeol()
                    except curses.error:
                        pass
        
        # Render Error Section
        error_start = max_y - 1 - error_h
        for i in range(error_h):
            y = error_start + i
            if y < 0:
                continue
            error_line = (" " + active_errors[i]).ljust(render_width)
            try:
                stdscr.addstr(y, 0, error_line[:render_width], curses.color_pair(3) | curses.A_BOLD)
            except curses.error:
                pass

        # Render Status Bar
        if max_y > 0:
            follow_txt = "FOLLOWING" if auto_scroll else "PAUSED"
            follow_hint = "Pause" if auto_scroll else "Follow"
            hints = f" (G:GPU C:CPU L:Log H:Hint T:Tool S:Mouse | F:{follow_hint} | Q:Quit) " if SETTINGS["show_hints"] else ""
            status_text = f" [{follow_txt}] (Line {scroll_pos}/{len(visible_log_lines)}){hints}"
            status_line = status_text.ljust(max_x-1)
            try:
                stdscr.addstr(max_y-1, 0, status_line[:max_x-1], curses.A_REVERSE)
                
                # Overlay status markers if space permits
                status_pos = max_x - 22
                if status_pos > len(status_text) + 2:
                    temp_color = get_temp_color(cpu_temp)
                    # Merge thermometer and color: symbol + color-based background
                    stdscr.addstr(max_y-1, status_pos, " 🌡 ", curses.A_REVERSE | temp_color)
                    
                    if active_errors:
                        stdscr.addstr(max_y-1, status_pos + 4, " ⚠️ ", curses.color_pair(11) | curses.A_REVERSE)
                    
                    log_active = (time.time() - last_log_update < 2.0)
                    log_text = "output" if log_active else "idle"
                    log_col = curses.color_pair(2) if log_active else curses.color_pair(3)
                    stdscr.addstr(max_y-1, status_pos + 9, f" {log_text} ", curses.A_REVERSE | log_col)
            except curses.error:
                pass

            # Update dynamic terminal title with color emojis
            # Scale: Blue < 35, Green < 55, Yellow < 70, Orange < 85, Red >= 85
            if cpu_temp < 35:
                t_mark = "🟦"
            elif cpu_temp < 55:
                t_mark = "🟩"
            elif cpu_temp < 70:
                t_mark = "🟨"
            elif cpu_temp < 85:
                t_mark = "🟧"
            else:
                t_mark = "🟥"
            
            e_part = " ⚠️" if active_errors else ""
            
            log_active = (time.time() - last_log_update < 2.0)
            log_text = " output" if log_active else " idle"
            sys.stdout.write(f"\033]0;👀 Watch Ollama {t_mark}{e_part}{log_text}\007")
            sys.stdout.flush()

        stdscr.refresh()

        # ── UPDATE TRACKING ──────────────────────────────────────────────
        last_term_size = curr_term_size
        last_smi_ver = curr_smi_ver
        last_log_ver = curr_log_ver
        last_error_sig = curr_error_sig
        last_scroll = scroll_pos
        last_auto = auto_scroll
        last_visible_lines = visible_log_lines
        render_dirty = False

if __name__ == "__main__":
    import sys
    sys.stdout.write("\033]0;👀 Watch Ollama\007")
    sys.stdout.flush()
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
    finally:
        # Disable mouse reporting
        print("\033[?1003l", end="")
        
        # Clean up the tail subprocess so we don't leave orphaned processes
        if _tail_proc is not None:
            try:
                _tail_proc.terminate()
            except Exception:
                pass
